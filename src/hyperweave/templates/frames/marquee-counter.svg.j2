{# HyperWeave Counter-Scroll Marquee — 800x140 tri-band instrument.
   Profile-dispatched: data presence drives rendering, not profile identity.
     envelope_stops present  -> chrome defs/content
     envelope_stops absent   -> brutalist defs/content
   3 rows with alternating R/L/R directions at unified speed.
   Specimens: chrome-horizon-marquees-v2 (chrome), brutalist-emerald-marquees-v5 (brutalist).
   Extends document.svg.j2.  Context: ComposeSpec dict. #}
{% extends "document.svg.j2" %}

{% block defs %}
{% set cw = width | default(800) %}
{% set ch = height | default(140) %}
{% set si = surface_inset | default(5) %}
{% set bz = bezel | default(4) %}
{% set n_rows = rows | length | default(3) %}
  {# Per-row clip paths #}
{% for row in rows %}
  <clipPath id="{{ uid }}-r{{ loop.index }}">
    <rect x="{{ clip_x | default(6) }}" y="{{ row.row_y }}" width="{{ clip_w | default(788) }}" height="{{ row.row_h }}"/>
  </clipPath>
{% endfor %}
  {# Edge fade gradients #}
  <linearGradient id="{{ uid }}-fade-l" x1="0" y1="0" x2="1" y2="0">
    <stop offset="0%" stop-color="{{ surface_hex | default('#0A0A0A') }}" stop-opacity="1"/>
    <stop offset="100%" stop-color="{{ surface_hex | default('#0A0A0A') }}" stop-opacity="0"/>
  </linearGradient>
  <linearGradient id="{{ uid }}-fade-r" x1="0" y1="0" x2="1" y2="0">
    <stop offset="0%" stop-color="{{ surface_hex | default('#0A0A0A') }}" stop-opacity="0"/>
    <stop offset="100%" stop-color="{{ surface_hex | default('#0A0A0A') }}" stop-opacity="1"/>
  </linearGradient>
{% if envelope_stops | default([]) %}
{% include "frames/marquee-counter/chrome-defs.j2" %}
{% else %}
{% include "frames/marquee-counter/brutalist-defs.j2" %}
{% endif %}
{% endblock %}

{% block content %}
{% set cw = width | default(800) %}
{% set ch = height | default(140) %}
{% set si = surface_inset | default(5) %}
{% set bz = bezel | default(4) %}
{% set fw = fade_width | default(36) %}

{# ══════════════════════════════════════════════════════════════════
   FRAME — dispatched to profile partials
   ══════════════════════════════════════════════════════════════════ #}
{% if envelope_stops | default([]) %}
{% include "frames/marquee-counter/chrome-content.j2" %}
{% else %}
{% include "frames/marquee-counter/brutalist-content.j2" %}
{% endif %}

{# ═══ Row dividers (data-driven: divider_stroke_width, divider_stroke_opacity) ═══ #}
{% for dy in divider_ys | default([44, 88]) %}
<line x1="{{ divider_x1 | default(si + 1) }}" y1="{{ dy }}" x2="{{ divider_x2 | default(cw - si - 1) }}" y2="{{ dy }}"
      stroke="var(--dna-signal)" stroke-width="{{ divider_stroke_width | default(1.5) }}" stroke-opacity="{{ divider_stroke_opacity | default('.2') }}"/>
{% endfor %}

{# ═══ Scroll rows ═══ #}
{% for row in rows %}
{% set row_idx = loop.index %}
{% set sd = row.scroll_distance | default(scroll_distance | default(1000)) %}
{% set dur = row.scroll_dur | default(scroll_dur | default(11.09)) %}
{% set dir = row.direction | default('rtl' if loop.index is odd else 'ltr') %}
<g clip-path="url(#{{ uid }}-r{{ row_idx }})">
  <g data-hw-zone="row-{{ row_idx }}">
    <animateTransform attributeName="transform" type="translate"
        from="{{ '-' ~ sd ~ ' 0' if dir == 'rtl' else '0 0' }}"
        to="{{ '0 0' if dir == 'rtl' else '-' ~ sd ~ ' 0' }}"
        dur="{{ dur }}s" repeatCount="indefinite"/>
    {# Set A — letter-spacing on word tspans only (not separators) for accurate measurement #}
    <g transform="translate(0,0)">
      <text y="{{ row.text_y }}"
            font-family="{{ row.font_family | default('var(--dna-font-mono, ui-monospace, monospace)') }}"
            font-size="{{ row.font_size | default(12) }}" font-weight="{{ row.font_weight | default('700') }}">
{% for item in row.cells %}
        <tspan {% if loop.first %}x="{{ row.text_start_x | default(20) }}"{% else %}dx="{{ item.dx | default(row.gap | default(28)) }}"{% endif %}
               fill="{{ item.color | default('var(--dna-signal)') }}" letter-spacing="{{ row.letter_spacing | default('2.5') }}"{% if item.font_size | default('') %} font-size="{{ item.font_size }}"{% endif %}{% if item.font_weight | default('') %} font-weight="{{ item.font_weight }}"{% endif %}{% if item.font_family | default('') %} font-family="{{ item.font_family }}"{% endif %}>{{ item.text }}</tspan>
{% if not loop.last and row.separator %}
        <tspan dx="{{ row.gap | default(28) }}" fill="{{ row.separator_color | default('var(--dna-border)') }}"{% if row.separator_opacity | default('') %} opacity="{{ row.separator_opacity }}"{% endif %}>{{ row.separator }}</tspan>
{% endif %}
{% endfor %}
      </text>
    </g>
    {# Set B (seamless loop duplicate at +scroll_distance) #}
    <g transform="translate({{ sd }},0)">
      <text y="{{ row.text_y }}"
            font-family="{{ row.font_family | default('var(--dna-font-mono, ui-monospace, monospace)') }}"
            font-size="{{ row.font_size | default(12) }}" font-weight="{{ row.font_weight | default('700') }}">
{% for item in row.cells %}
        <tspan {% if loop.first %}x="{{ row.text_start_x | default(20) }}"{% else %}dx="{{ item.dx | default(row.gap | default(28)) }}"{% endif %}
               fill="{{ item.color | default('var(--dna-signal)') }}" letter-spacing="{{ row.letter_spacing | default('2.5') }}"{% if item.font_size | default('') %} font-size="{{ item.font_size }}"{% endif %}{% if item.font_weight | default('') %} font-weight="{{ item.font_weight }}"{% endif %}{% if item.font_family | default('') %} font-family="{{ item.font_family }}"{% endif %}>{{ item.text }}</tspan>
{% if not loop.last and row.separator %}
        <tspan dx="{{ row.gap | default(28) }}" fill="{{ row.separator_color | default('var(--dna-border)') }}"{% if row.separator_opacity | default('') %} opacity="{{ row.separator_opacity }}"{% endif %}>{{ row.separator }}</tspan>
{% endif %}
{% endfor %}
      </text>
    </g>
  </g>
</g>
{% endfor %}

{# ═══ Edge fades (data-driven: fade_x, fade_y, fade_w, fade_h) ═══ #}
<rect x="{{ fade_x | default(si) }}" y="{{ fade_y | default(si) }}" width="{{ fw }}" height="{{ fade_h | default(ch - si * 2) }}"
      {% if fade_rx | default('') %}rx="{{ fade_rx }}"{% endif %}
      fill="url(#{{ uid }}-fade-l)"/>
<rect x="{{ fade_right_x | default(cw - si - fw) }}" y="{{ fade_y | default(si) }}" width="{{ fw }}" height="{{ fade_h | default(ch - si * 2) }}"
      {% if fade_rx | default('') %}rx="{{ fade_rx }}"{% endif %}
      fill="url(#{{ uid }}-fade-r)"/>

{# ═══ Corner rivets + status beacon (brutalist only, guard on data) ═══ #}
{% if show_rivets | default(false) %}
{% set rs = rivet_size | default(6) %}
{% set ri = si + 3 %}
{% for pos in [(ri, ri), (cw - ri - rs, ri), (ri, ch - ri - rs), (cw - ri - rs, ch - ri - rs)] %}
<rect x="{{ pos[0] }}" y="{{ pos[1] }}" width="{{ rs }}" height="{{ rs }}"
      fill="var(--dna-signal)" opacity="{{ rivet_opacity | default(0.4) }}"/>
{% endfor %}
{% endif %}

{% if show_beacon | default(false) %}
{# Status beacon (right edge) #}
<rect x="{{ cw - 12 }}" y="{{ (ch - 16) // 2 }}" width="6" height="16"
      fill="var(--dna-signal)">
  <animate attributeName="opacity" values="1;.3;1" dur="{{ beacon_pulse_dur | default('2.618s') }}"
           repeatCount="indefinite"/>
</rect>
{% endif %}

{# Specular overlay removed from chrome marquees #}
{% endblock %}
