{# Session Receipt 800x500 (v0.2.21 risograph-canonical). Thin render: zero math, zero hex.
   Geometry from compose/treemap.py + bar_chart.py; colors from var(--dna-*).
   Same structure for ALL skins; palette swaps via genome JSON.
   Specimen: tier2/telemetry/telemetry-redesign/receipt-genome-risograph.svg #}
{% extends "document.svg.j2" %}

{% block defs %}
{% include "partials/provider-glyphs.svg.j2" %}
{# Card-shape clipPath — defines the receipt's rounded outline so any element
   that paints to the SVG edges (substrate, top accent strip) inherits the
   rounding instead of poking out as square corners around the rounded card.
   Matches the claude-code v9 specimen's #card-shape pattern. The card_border
   outer stroke uses the same rx=5.5 so all three edges align. #}
<clipPath id="receipt-card-shape">
  <rect width="{{ width }}" height="{{ height }}" rx="5.5" ry="5.5"/>
</clipPath>
{# Atmosphere gradient (v0.2.23, codex skin). Diagonal linear gradient
   painted behind the substrate when the genome declares ``atmosphere_stops``.
   Empty list = no atmosphere = current behavior preserved across other skins. #}
{% if atmosphere_stops %}
<linearGradient id="receipt-atmosphere" x1="0" y1="0" x2="1" y2="1">
{% for stop in atmosphere_stops %}
  <stop offset="{{ stop.offset }}" stop-color="{{ stop.color }}"/>
{% endfor %}
</linearGradient>
{% endif %}
{# Radial bloom overlays — additive lightness over the atmosphere
   (v9 codex bloom-cool + bloom-violet). #}
{% for bloom in atmosphere_blooms %}
<radialGradient id="receipt-{{ bloom.id }}" cx="{{ bloom.cx }}" cy="{{ bloom.cy }}" r="{{ bloom.r }}">
{% for stop in bloom.stops %}
  <stop offset="{{ stop.offset }}" stop-color="{{ stop.color }}" stop-opacity="{{ stop.opacity }}"/>
{% endfor %}
</radialGradient>
{% endfor %}
{# Card top highlight — white→transparent gradient suggesting a glass edge. #}
{% if card_top_highlight %}
<linearGradient id="receipt-card-top-highlight" x1="0" y1="0" x2="0" y2="1">
  <stop offset="0%" stop-color="#FFFFFF" stop-opacity="0.35"/>
  <stop offset="100%" stop-color="#FFFFFF" stop-opacity="0"/>
</linearGradient>
{% endif %}
{% endblock %}

{% block content %}
{# Atmosphere backdrop (v0.2.23): full-canvas gradient painted FIRST, then the
   substrate inset by ``card_inset`` so the atmosphere is visible as a colored
   ring around the card. Both fields default to empty/zero — other skins keep
   their current full-canvas substrate behavior unchanged. #}
{% if atmosphere_stops %}
<rect width="{{ width }}" height="{{ height }}" rx="5.5" ry="5.5" fill="url(#receipt-atmosphere)"/>
{% for bloom in atmosphere_blooms %}
<rect width="{{ width }}" height="{{ height }}" rx="5.5" ry="5.5" fill="url(#receipt-{{ bloom.id }})"/>
{% endfor %}
<rect x="{{ card_inset }}" y="{{ card_inset }}" width="{{ width - 2 * card_inset }}" height="{{ height - 2 * card_inset }}" rx="3" ry="3" fill="var(--dna-surface)"/>
{% if card_top_highlight %}
<rect x="{{ card_inset }}" y="{{ card_inset }}" width="{{ width - 2 * card_inset }}" height="32" rx="3" ry="3" fill="url(#receipt-card-top-highlight)" pointer-events="none"/>
{% endif %}
{% else %}
<rect width="{{ width }}" height="{{ height }}" rx="5.5" ry="5.5" fill="var(--dna-surface)"/>
{% endif %}

{# ═══ HERO ZONE (translate 24, 18 — risograph-canonical) ═══ #}
{% if has_glyph %}
<use href="#{{ glyph_id }}" x="24" y="13" width="18" height="18"/>
{% endif %}
<text x="{{ provider_label_x | default(50) }}" y="27" class="s ink1" font-size="14" font-weight="700">{{ provider_label }}</text>
{% if model_label %}
<text x="{{ model_label_x | default(142) }}" y="27" class="m ink2" font-size="11" letter-spacing="0.04em">· {{ model_label }}</text>
{% endif %}
{# Phase pill at top-right — token-driven, branch-free.
   Voltage (titanium spec): layered structure — dark outer base + thin frame
   stroke + champagne phosphor inner + white/orange hairlines + dark text.
   Claude-code: single bright pill — outer/stroke/rules transparent, solid
   terra-coral inner + white text. The v9 specimen used rx=11 (full pill);
   the canonical v0.2.21 silhouette is square (rx=0) across all skins for
   cross-skin coherence (locked by test_pill_rx_normalized_to_square_across_skins).
   Cream (risograph spec): layered like voltage but with cream-shifted base,
   dark-brown frame, fluoro-orange phosphor inner, light cream text + hairlines.
   "transparent" tokens render the rect but paint no pixels — same template,
   three different identities, zero conditionals. #}
<g transform="translate({{ pill_x }}, 11)" data-hw-zone="phase-pill">
  <rect width="{{ pill_w }}" height="22" rx="{{ pill_rx }}" fill="var(--dna-pill-outer-bg)"/>
  <rect width="{{ pill_w }}" height="22" rx="{{ pill_rx }}" fill="none" stroke="var(--dna-pill-outer-stroke)" stroke-width="0.75"/>
  <rect class="anchor-live" x="2" y="2" width="{{ pill_w - 4 }}" height="18" rx="{{ pill_rx }}" fill="var(--dna-pill-inner-bg)"/>
  <rect x="2" y="2" width="{{ pill_w - 4 }}" height="1" fill="var(--dna-pill-rule-top)"/>
  <rect x="2" y="19" width="{{ pill_w - 4 }}" height="1" fill="var(--dna-pill-rule-bottom)"/>
  <text class="m" x="{{ pill_w // 2 }}" y="14" text-anchor="middle" font-size="9" font-weight="800" letter-spacing="0.28em" fill="var(--dna-pill-text)">{{ pill_label }}</text>
</g>
{# Hero headline: tokens billed (ink) + ${cost} (signal color), weight=800 #}
<text x="24" y="66" class="s ink1" font-size="26" font-weight="800" letter-spacing="-0.02em"><tspan>{{ headline_tokens }}</tspan><tspan fill="var(--dna-signal)">{{ headline_cost }}</tspan></text>
<text x="24" y="82" class="m ink3" font-size="10" letter-spacing="0.04em">{{ hero_subline }}</text>
{# Hero-right stats (right-aligned mono ink2 lines at y=56/70/84) #}
<g data-hw-zone="hero-right">
{% for stat in hero_right_stats | default([]) %}
<text x="{{ content_right_x }}" y="{{ stat.y }}" class="m ink2" font-size="10" text-anchor="end" letter-spacing="0.02em"
  {% if stat.accent == 'failing' %}fill="var(--dna-status-failing-core)" font-weight="600"{% endif %}>{{ stat.text }}</text>
{% endfor %}
</g>
<line x1="24" y1="96" x2="{{ content_right_x }}" y2="96" stroke="var(--dna-border)" stroke-width="1"/>

{# ═══ TREEMAP ZONE (translate 24, 104 — header INSIDE zone) ═══ #}
<g transform="translate(24, 104)" data-hw-zone="treemap">
  {# Header row: TOKEN MAP lab + 4 color-class chips + ✗N hint.
     The "BY TOOL · N SOURCES" subtitle that v9 has lives at a different
     position (between the title and chips) — without resolver-side width
     measurement the subtitle collided with chips at the same x. Removed
     until it can be properly placed via computed positioning. #}
  <text class="m ink3" font-size="7" font-weight="700" letter-spacing="0.22em" y="12">TOKEN MAP</text>
{% for chip in treemap_header_chips | default([]) %}
  <rect x="{{ chip.x }}" y="6" width="2" height="8" fill="var(--dna-tool-{{ chip.tool_class }})"/>
  <text class="m ink3" x="{{ chip.x + 6 }}" y="13" font-size="9">{{ chip.label }}</text>
{% endfor %}
  <text class="m ink3" x="{{ content_w }}" y="13" font-size="9" text-anchor="end"><tspan fill="var(--dna-status-failing-core)" opacity="0.85" font-weight="700">✗N</tspan><tspan dx="3">= failed tool calls</tspan></text>

  {# Tier cells — full-width top accent on every cell, hero metric on tier-1 #}
{% for cell in treemap_cells | default([]) %}
  <g transform="translate({{ cell.x }}, {{ cell.y }})" data-hw-tier="{{ cell.tier }}" data-hw-tool="{{ cell.name }}"{% if cell.is_overflow %} data-hw-overflow="true"{% endif %}>
    <rect width="{{ cell.w }}" height="{{ cell.h }}" fill="var(--dna-surface-deep)"/>
    <rect width="{{ cell.accent_w }}" height="{{ cell.accent_h }}" fill="var(--dna-tool-{{ cell.tool_class }})" opacity="0.85"/>
    <rect width="{{ cell.w }}" height="{{ cell.h }}" fill="none" stroke="var(--dna-border)" stroke-width="0.5"/>
{# Cell text — positions/sizes are computed in compose/treemap.py per cell;
   the template never decides geometry, only renders what was decided. The
   ``show_detail`` flag is False when the cell can't fit both label + detail
   without overflow (catches small cells safely). #}
{% if cell.is_hero %}
    {# Tier-1 hero treatment: percentage at tier-1 hero font size in tool color,
       label and detail at compose-computed offsets. v9 specimen: pct y=58 size=36,
       detail y=72 size=10 — 6px gap between pct baseline and detail top. #}
    <text class="m ink1" font-size="{{ cell.label_size }}" font-weight="600" x="14" y="{{ cell.label_y }}">{{ cell.label }}</text>
    <text class="s" font-size="{{ cell.pct_size }}" font-weight="800" fill="var(--dna-tool-{{ cell.tool_class }})" x="14" y="{{ cell.pct_y }}" letter-spacing="-0.02em">{{ cell.pct }}%</text>
{% if cell.show_detail %}
    <text class="m ink3" font-size="{{ cell.detail_size }}" x="14" y="{{ cell.detail_y }}">{{ cell.detail }}</text>
{% endif %}
{% if cell.errors %}
    <g transform="translate({{ cell.w - 8 }}, 14)">
      <rect x="-24" y="-10" width="22" height="14" fill="var(--dna-surface-deep)" stroke="var(--dna-status-failing-core)" stroke-opacity="0.35" stroke-width="0.5"/>
      <text class="m" font-size="8" font-weight="700" fill="var(--dna-status-failing-core)" x="-13" y="0" text-anchor="middle">✗{{ cell.errors }}</text>
    </g>
{% endif %}
{% else %}
    {# Tier-2 + Tier-3: name + (optional) detail + inline error badge #}
    <text class="m ink1" font-size="{{ cell.label_size }}" font-weight="600" x="10" y="{{ cell.label_y }}">{{ cell.label }}</text>
{% if cell.show_detail %}
    <text class="m ink3" font-size="{{ cell.detail_size }}" x="10" y="{{ cell.detail_y }}">{{ cell.detail }}</text>
{% endif %}
{% if cell.errors %}
    <text class="m" font-size="8" font-weight="700" fill="var(--dna-status-failing-core)" x="{{ cell.w - 8 }}" y="{{ cell.label_y }}" text-anchor="end">✗{{ cell.errors }}</text>
{% endif %}
{% endif %}
  </g>
{% endfor %}
</g>
<line x1="24" y1="290" x2="{{ content_right_x }}" y2="290" stroke="var(--dna-border)" stroke-width="1"/>

{# ═══ RHYTHM ZONE (translate 24, 306 — risograph-canonical) ═══ #}
<g transform="translate(24, 306)" data-hw-zone="rhythm">
  {# Header composite: LEFT lab + RIGHT mono total/peak #}
  <text class="m ink3" font-size="7" font-weight="700" letter-spacing="0.22em">{{ rhythm_header_left }}</text>
  <text class="m ink3" x="{{ content_w }}" y="0" font-size="7.5" text-anchor="end" letter-spacing="0.18em">{{ rhythm_header_right }}</text>

  {# Time axis labels ABOVE the bar track at major intervals #}
{% for tick in time_axis_ticks | default([]) %}
{% if tick.is_major %}
  <text class="m ink3" x="{{ tick.x }}" y="20" font-size="8"{% if loop.first %}{% elif loop.last %} text-anchor="end"{% else %} text-anchor="middle"{% endif %}>{{ tick.label }}</text>
{% endif %}
{% endfor %}

  {# Vertical grid lines at major time intervals (across bar track only) #}
{% for grid in rhythm_grid_lines | default([]) %}
  <line x1="{{ grid.x }}" y1="30" x2="{{ grid.x }}" y2="{{ rhythm_baseline_y }}" stroke="var(--dna-border-tint)" stroke-width="0.5" opacity="0.55"/>
{% endfor %}

  {# Baseline rule across full track width #}
  <line x1="0" y1="{{ rhythm_baseline_y }}" x2="{{ content_w }}" y2="{{ rhythm_baseline_y }}" stroke="var(--dna-border)" stroke-width="1"/>

  {# Variable-height bars (opacity from BarChartCell) #}
  <g data-hw-field="bars">
{% for bar in rhythm_bars | default([]) %}
    <rect x="{{ bar.x }}" y="{{ bar.y }}" width="{{ bar.w }}" height="{{ bar.h }}" fill="var(--dna-tool-{{ bar.tool_class }})" opacity="{{ bar.opacity }}" rx="0.3"/>
{% endfor %}
  </g>

  {# Peak marker: 1.5px signal-color tick at top of max-tokens bar #}
{% if rhythm_peak_marker %}
  <rect x="{{ rhythm_peak_marker.x }}" y="{{ rhythm_peak_marker.y }}" width="{{ rhythm_peak_marker.w }}" height="{{ rhythm_peak_marker.h }}" fill="var(--dna-signal)"/>
{% endif %}

  {# Error ticks: dedicated band ABOVE bars (1.2x5px red marks) #}
  <g data-hw-field="errors">
{% for tick in rhythm_error_ticks | default([]) %}
    <rect x="{{ tick.x }}" y="{{ tick.y }}" width="{{ tick.w }}" height="{{ tick.h }}" fill="var(--dna-status-failing-core)" opacity="0.85"/>
{% endfor %}
  </g>

  {# Legend at panel bottom: 4 tool swatches + error-tick swatch + DOMINANT label #}
  <g transform="translate(0, {{ rhythm_baseline_y + 16 }})" data-hw-zone="legend">
{% for entry in phase_legend | default([]) %}
{% if entry.kind == 'error' %}
    <rect x="{{ entry.x }}" y="0" width="2" height="6" fill="var(--dna-status-failing-core)"/>
    <text class="m ink3" x="{{ entry.x + 6 }}" y="6" font-size="8.5">{{ entry.label }}</text>
{% else %}
    <rect x="{{ entry.x }}" y="0" width="6" height="6" fill="var(--dna-tool-{{ entry.id }})"/>
    <text class="m ink3" x="{{ entry.x + 10 }}" y="6" font-size="8.5">{{ entry.label }}</text>
{% endif %}
{% endfor %}
    <text class="m" x="{{ content_w }}" y="6" font-size="9" font-weight="700" fill="var(--dna-signal)" text-anchor="end" letter-spacing="0.14em">{{ rhythm_dominant_label }}</text>
  </g>
</g>

{# ═══ FOOTER (4-quadrant) ═══ #}
<line x1="24" y1="452" x2="{{ content_right_x }}" y2="452" stroke="var(--dna-border)" stroke-width="0.5"/>
<text x="24" y="470" class="m ink3" font-size="9" letter-spacing="0.04em">{{ footer_tl }}</text>
<text x="{{ content_right_x }}" y="470" class="m ink3" font-size="9" text-anchor="end" letter-spacing="0.04em">{{ footer_tr }}</text>
<text x="24" y="487" class="m ink2" font-size="9" letter-spacing="0.04em">{{ footer_bl }}</text>
<text x="{{ content_right_x }}" y="487" class="m ink2" font-size="9" text-anchor="end" letter-spacing="0.04em">{{ footer_br }}</text>

{# Card chrome — token-driven, branch-free.
   Top accent strip: rendered for every skin; transparent on voltage + cream
   (no top stripe per their specimens), terra-coral on claude-code per the v9
   specimen. The rect always emits — its visibility comes from the genome.
   Outer frame: 1px stroke at the SVG edge. Voltage = subtle dark gray
   (#2F3540), cream = dark brown (#1A1510), claude-code = terra-coral
   (#D97757). Rendered for every skin; the genome chooses the color. #}
<rect x="0" y="0" width="{{ width }}" height="2" fill="var(--dna-card-border-top)" fill-opacity="0.85" clip-path="url(#receipt-card-shape)"/>
<rect x="0.5" y="0.5" width="{{ width - 1 }}" height="{{ height - 1 }}" rx="5.5" ry="5.5" fill="none" stroke="var(--dna-card-border)" stroke-width="1"/>
{% endblock %}
