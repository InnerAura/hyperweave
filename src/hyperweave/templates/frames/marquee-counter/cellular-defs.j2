{# Cellular counter-marquee defs.

   The shared marquee-counter.svg.j2 outer defs block provides the per-row
   uid-r{N} clip paths and uid-fade-l/uid-fade-r gradients using surface_hex
   (= #04060A for automata). Cellular only needs font-face declarations
   plus reduced-motion gates for each row's animateTransform. The shared
   template emits row dividers using the per-paradigm divider_stroke_width
   and divider_stroke_opacity values (set by _resolve_counter to 0.5/0.15
   for cellular bifamily). #}
<style>{{ font_faces | safe }}
@media(prefers-reduced-motion:reduce){
  [data-hw-zone^="row-"]{animation:none!important}
}
</style>
