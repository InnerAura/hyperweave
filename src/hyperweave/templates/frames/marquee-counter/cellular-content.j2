{# Cellular counter-marquee content — hairline-bridge tri-band chrome.

   Spec vocabulary (mirroring the horizontal/vertical cellular language):
   no frame plate, no rivets, no left-edge accent bar. Just void ground
   plus top teal hairline and bottom amethyst hairline. The shared
   marquee-counter.svg.j2 renders three scroll rows whose cell colors
   were already mapped to row_palette[teal/amethyst/teal] in
   _resolve_counter; row dividers are emitted by the shared template at
   0.5px / 0.15 opacity (set there by paradigm dispatch). #}
{% set teal_info = family_blue_seam_mid | default('#3A9FB8') %}
{% set amethyst_info = family_purple_seam_mid | default('#A88AD4') %}

{# Void ground — sourced via surface_hex (= #04060A for automata). #}
<rect width="{{ cw }}" height="{{ ch }}" fill="{{ surface_hex | default('#04060A') }}"/>

{# Top hairline — abyssal-teal signature. Shifted off the absolute top
   edge by 1px so it doesn't get clipped by parent rendering frames. #}
<rect x="0" y="0" width="{{ cw }}" height="0.5" fill="{{ teal_info }}" opacity="0.25"/>

{# Bottom hairline — cyber-amethyst signature, mirroring the top. #}
<rect x="0" y="{{ ch - 0.5 }}" width="{{ cw }}" height="0.5" fill="{{ amethyst_info }}" opacity="0.25"/>
