{# Chrome counter-marquee content: env-map bezel, groove, well, specular accents.
   Specimen: chrome-horizon-marquees-v2.
   Layer order: envelope -> groove -> well -> left accent -> top specular catch. #}
<g clip-path="url(#{{ uid }}-outer)" filter="url(#{{ uid }}-shadow)">
  <rect width="{{ cw }}" height="{{ ch }}" rx="4" fill="url(#{{ uid }}-envelope)"/>
</g>
<rect x="2" y="2" width="{{ cw - 4 }}" height="{{ ch - 4 }}" rx="3" fill="none" stroke="#000510" stroke-width=".6"/>
<rect x="3" y="3" width="{{ cw - 6 }}" height="{{ ch - 6 }}" rx="2" fill="url(#{{ uid }}-well)"/>
{# Specular sweep removed — causes text blur on chrome marquees #}
<rect x="3" y="3" width="4" height="{{ ch - 6 }}" fill="url(#{{ uid }}-envelope)" opacity="0.7"/>
<rect x="60" y="3" width="{{ cw - 120 }}" height=".5" fill="{{ specular_light }}" opacity=".1"/>
