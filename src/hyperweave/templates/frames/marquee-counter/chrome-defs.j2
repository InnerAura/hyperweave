{# Chrome counter-marquee defs: envelope, shadow, well, clip paths.
   Specimen: chrome-horizon-marquees-v2.
   Guard on data presence (envelope_stops), not profile identity. #}
  <linearGradient id="{{ uid }}-envelope" x1="0" x2="0" y1="0" y2="1">
  {% for stop in envelope_stops %}
    <stop offset="{{ stop.offset }}" stop-color="{{ stop.color }}"/>
  {% endfor %}
  </linearGradient>
  <filter id="{{ uid }}-shadow" x="-1%" y="-4%" width="102%" height="112%">
    <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#000" flood-opacity=".35"/>
  </filter>
  <clipPath id="{{ uid }}-outer"><rect width="{{ cw }}" height="{{ ch }}" rx="4"/></clipPath>
  <clipPath id="{{ uid }}-inner"><rect x="3" y="3" width="{{ cw - 6 }}" height="{{ ch - 6 }}" rx="2"/></clipPath>
  <linearGradient id="{{ uid }}-well" x1="0" x2="0" y1="0" y2="1">
    <stop offset="0%" stop-color="{{ well_top | default('#0C1E2E') }}"/>
    <stop offset="100%" stop-color="{{ well_bottom | default('#06101A') }}"/>
  </linearGradient>
  {# Specular sweep removed -- mobile WebKit text blur #}
