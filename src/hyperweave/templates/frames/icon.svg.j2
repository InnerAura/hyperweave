{# HyperWeave Icon Frame — Profile-dispatched, 64x64.
   Templates never check genome identity. Data presence drives rendering:
     envelope_stops present  → chrome defs/content
     envelope_stops absent   → brutalist defs/content
   FOUR frame variants selected by icon_variant context var:
     1. brutalist-circular  (specimen: brutalist-icon-frames/brutalist-emerald-circular-v2.svg)
     2. brutalist-square    (specimen: brutalist-icon-frames/brutalist-emerald-square-v2.svg)
     3. binary-circular     (specimen: chrome-horizon-new/icon-circle-v2.svg)
     4. binary-square       (specimen: chrome-horizon-new/icon-square-v2.svg)
   Extends document.svg.j2. #}
{% extends "document.svg.j2" %}

{% block defs %}
{% if envelope_stops | default([]) %}
{% include "frames/icon/chrome-defs.j2" %}
{% else %}
{% include "frames/icon/brutalist-defs.j2" %}
{% endif %}
{% endblock %}

{% block content %}
{% set icon_size = width | default(64) %}
{% set cx = icon_size / 2 %}

{% if envelope_stops | default([]) %}
{% include "frames/icon/chrome-content.j2" %}
{% else %}
{% include "frames/icon/brutalist-content.j2" %}
{% endif %}

{# Border motion SMIL overlay (shared across all profiles) #}
{% if motion_border_defs | default('') %}
<defs>{{ motion_border_defs | safe }}</defs>
{% endif %}
{% if motion_border_overlay | default('') %}
{{ motion_border_overlay | safe }}
{% endif %}
{% endblock %}
