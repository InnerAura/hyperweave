{# HyperWeave Timeline Frame — Vertical roadmap node chain (Session 2A+2B).

   POST /v1/timeline/{genome}.{motion} with JSON body {items: [...]}.
   The resolver precomputes per-item y offset, opacity cascade, and node shape
   (from genome.structural.data_point_shape) so this template just loops. #}
{% extends "document.svg.j2" %}

{% block defs %}
<style>
.hw-timeline-title { font-family: var(--dna-font-display, 'Barlow Condensed','Bebas Neue',sans-serif); font-weight: 900; letter-spacing: 0.08em; }
.hw-timeline-node-title { font-family: var(--dna-font-display, 'Barlow Condensed',sans-serif); font-weight: 800; letter-spacing: 0.02em; }
.hw-timeline-node-sub { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); letter-spacing: 0.1em; }
.hw-timeline-date { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); letter-spacing: 0.12em; }
.hw-timeline-spine {
  stroke: var(--dna-border);
  stroke-width: 2;
  fill: none;
  stroke-dasharray: 6 4;
}
@media (prefers-reduced-motion: no-preference) {
  .hw-timeline-spine { animation: hw-timeline-flow 8s linear infinite; }
}
@keyframes hw-timeline-flow {
  from { stroke-dashoffset: 0; }
  to { stroke-dashoffset: -20; }
}
@media (prefers-reduced-motion: reduce) {
  .hw-timeline-spine { animation: none; }
}
</style>
{% endblock %}

{% block content %}
{% set tw = width | default(800) %}
{% set th = height | default(400) %}
{% set spine_x = timeline_spine_x | default(80) %}

{# Void background + genome accent bar #}
<rect width="{{ tw }}" height="{{ th }}" fill="var(--dna-surface)"/>
<rect width="6" height="{{ th }}" fill="var(--dna-signal)"/>

{# Title #}
<text x="{{ spine_x + 16 }}" y="44" class="hw-timeline-title" font-size="26" fill="var(--dna-ink-primary)">{{ timeline_title | upper }}</text>
<text x="{{ tw - 20 }}" y="44" class="hw-timeline-date" font-size="7" fill="var(--dna-ink-muted)" text-anchor="end" opacity="0.4">HYPERWEAVE · TIMELINE</text>

{# Vertical spine connecting nodes, with dash flow animation #}
{% if timeline_items %}
{% set first_y = timeline_items[0].y %}
{% set last_y = timeline_items[-1].y %}
<path class="hw-timeline-spine" d="M{{ spine_x }},{{ first_y }} L{{ spine_x }},{{ last_y }}"/>
{% endif %}

{# Nodes #}
{% include "frames/timeline/" ~ (paradigm | default("default")) ~ "-content.j2" %}
{% endblock %}
