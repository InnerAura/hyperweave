{# Cellular marquee-horizontal OVERLAY — top + bottom bifamily hairlines.
   Renders above the scroll-track text so text visually slides UNDER the
   hairlines at the top/bottom edges (instead of overlapping them).
   Specimen: cellular-automata-marquee-current.svg.
#}
{% set teal_info = family_blue_seam_mid | default('#3A9FB8') %}
{% set amethyst_info = family_purple_seam_mid | default('#A88AD4') %}

{# Top hairline — abyssal-teal signature #}
<rect x="0" y="0" width="{{ mw }}" height="0.5" fill="{{ teal_info }}" opacity="0.25"/>

{# Bottom hairline — cyber-amethyst signature #}
<rect x="0" y="{{ mh - 0.5 }}" width="{{ mw }}" height="0.5" fill="{{ amethyst_info }}" opacity="0.25"/>
