{# glyph cell — brand/identity mark from the glyph registry. Tint selection
   (ink / brand / full) degrades through what the entry carries: multicolor
   color_paths master, uid-scoped gradient, scalar brand color, genome ink.
   A registry fill-rule rides the group (evenodd marks break without it). #}
  <g transform="{{ cell.glyph_transform }}"{% if cell.glyph_gradient %} fill="url(#{{ uid }}-gg-{{ cell.glyph_gradient }})"{% elif cell.glyph_fill %} fill="{{ cell.glyph_fill }}"{% endif %}{% if cell.glyph_fill_rule %} fill-rule="{{ cell.glyph_fill_rule }}"{% endif %} opacity="{{ cell.glyph_opacity }}" data-hw-cell="glyph">
{% for p in cell.glyph_paths %}
    <path d="{{ p.d }}"{% if p.fill %} fill="{{ p.fill }}"{% endif %}/>
{% endfor %}
  </g>
