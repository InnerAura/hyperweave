{# HyperWeave Strip Frame — Paradigm-dispatched (Principle 26, Session 2A+2B).

   Session 2A+2B migration: templates dispatch by abstract paradigm name
   declared in `genome.paradigms.strip`, not by data-presence or genome identity.

   Built-in paradigms:
     "default" → brutalist partial (flat plate, class-based separators)
     "chrome"  → chrome partial (envelope gradient, well, url() separators)

   Zone layout: plate bg → border → accent bar → glyph →
   identity text → [divider → metric cell]* → divider → status indicator.
   Metric cells repeat at ~106px pitch.
   Extends document.svg.j2. #}
{% extends "document.svg.j2" %}

{% block defs %}
{% include "frames/strip/" ~ (paradigm | default("default")) ~ "-defs.j2" %}
<clipPath id="{{ uid }}-clip">
  <rect width="{{ width }}" height="{{ height }}"/>
</clipPath>
{% endblock %}

{% block content %}
{% set strip_h = height | default(52) %}
{% set accent_w = accent_bar_width | default(6) %}
{% set glyph_size = 24 %}
{% set glyph_cx = accent_w + 12 + (glyph_size // 2) %}
{% set glyph_cy = strip_h // 2 %}
{% set identity_x = (glyph_cx + (glyph_size // 2) + 9) if glyph_path else (accent_w + 14) %}
{% set metric_pitch = metric_pitch | default(106) %}
{% set indicator_size = 14 %}
{% set div_y1 = 12 %}
{% set div_y2 = strip_h - 12 %}
{% set paradigm_strip = paradigm | default("default") %}

{# === Frame structure (paradigm-dispatched via include — polymorphism, not a branch) === #}
{% include "frames/strip/" ~ paradigm_strip ~ "-content.j2" %}

{# === Glyph zone (profile-parametric: size and fill from profile YAML) === #}
{% if glyph_path %}
{% set gs = strip_glyph_size | default(20) %}
{% set gf = strip_glyph_fill | default('var(--dna-signal)') %}
<g data-hw-zone="glyph" transform="translate({{ glyph_cx }},{{ glyph_cy }})">
  <svg x="{{ -(gs // 2) }}" y="{{ -(gs // 2) }}"
       width="{{ gs }}" height="{{ gs }}"
       viewBox="{{ glyph_viewbox }}">
    <path d="{{ glyph_path }}" fill="{{ glyph_fill | default(gf) }}"/>
  </svg>
</g>
{% endif %}

{# === Identity text (clipped to zone before first divider) === #}
{% set first_div_x = first_divider_x | default(143) %}
<defs>
  <clipPath id="{{ uid }}-id-clip">
    <rect x="{{ accent_w }}" y="0" width="{{ first_div_x - accent_w }}" height="{{ strip_h }}"/>
  </clipPath>
</defs>
<g clip-path="url(#{{ uid }}-id-clip)">
  <text data-hw-zone="identity"
        x="{{ identity_x }}" y="{{ (strip_h // 2) + 4 }}"
        class="{{ uid }}-identity">{{ identity | upper }}</text>
</g>

{# === Metric cells with dividers === #}
{% set first_div_x = first_divider_x | default(143) %}
{% set cell_start = first_div_x + 12 %}
{# First divider — stroke sourced from resolver-injected context:
   divider_render_mode = "gradient" → chrome-defs url(#...-sep) gradient
   divider_render_mode = "class"    → profile-declared flat color.
   Decision lives in paradigm YAML, not in a template branch on slug. #}
{% if divider_render_mode == "gradient" %}
<line x1="{{ first_div_x }}" y1="{{ div_y1 }}"
      x2="{{ first_div_x }}" y2="{{ div_y2 }}"
      stroke="url(#{{ uid }}-sep)" stroke-width="1"/>
{% else %}
<line x1="{{ first_div_x }}" y1="{{ div_y1 }}"
      x2="{{ first_div_x }}" y2="{{ div_y2 }}"
      stroke="{{ strip_divider_color | default('var(--dna-border)') }}"
      stroke-width="1"
      opacity="{{ strip_divider_opacity | default(1.0) }}"/>
{% endif %}

{% for metric in metrics %}
{% set cell_x = cell_start + (loop.index0 * metric_pitch) %}
<g data-hw-zone="metric-{{ loop.index0 }}" transform="translate({{ cell_x }},0)">
  <text x="{{ metric_pitch // 2 }}" y="{{ strip_metric_label_y | default(18) }}" text-anchor="middle"
        class="{{ uid }}-metric-label">{{ metric.label | upper }}</text>
  {# Metric value — skew applied only when strip_metric_value_skew != 0
     (was hardcoded to paradigm=chrome; now chrome.yaml sets skew=0 for badge
     parity, removing the Impact-italic treatment that diverged from badge's
     upright Orbitron). #}
  {% set _skew = strip_metric_value_skew | default(0) %}
  {% if _skew != 0 %}
  <g transform="translate({{ metric_pitch // 2 }},{{ strip_metric_value_y | default(36) }}) skewX({{ _skew }})">
    <text x="0" y="0" text-anchor="middle" dominant-baseline="central"
          class="{{ uid }}-metric-value">{{ metric.value }}</text>
  </g>
  {% else %}
  <text x="{{ metric_pitch // 2 }}" y="{{ strip_metric_value_y | default(36) }}" text-anchor="middle"
        class="{{ uid }}-metric-value">{{ metric.value }}</text>
  {% endif %}
{% if metric.delta %}
  <text x="{{ metric_pitch // 2 }}" y="48" text-anchor="middle"
        class="hw-delta hw-delta--{{ metric.delta_dir | default('neutral') }}">{{ metric.delta }}</text>
{% endif %}
</g>
{# Trailing divider after each metric — same divider_render_mode as above. #}
{% set trail_x = cell_start + (loop.index * metric_pitch) %}
{% if divider_render_mode == "gradient" %}
<line x1="{{ trail_x }}" y1="{{ div_y1 }}"
      x2="{{ trail_x }}" y2="{{ div_y2 }}"
      stroke="url(#{{ uid }}-sep)" stroke-width="1"/>
{% else %}
<line x1="{{ trail_x }}" y1="{{ div_y1 }}"
      x2="{{ trail_x }}" y2="{{ div_y2 }}"
      stroke="{{ strip_divider_color | default('var(--dna-border)') }}"
      stroke-width="1"
      opacity="{{ strip_divider_opacity | default(1.0) }}"/>
{% endif %}
{% endfor %}

{# === Status indicator (paradigm-dispatched) ===
   Single diamond at the right-edge status slot. The specimen anchors the
   diamond here so the right edge reads as a deliberate terminus rather
   than an isolated afterthought — the status_zone (56px) reserved by
   resolve_strip gives it visual integration, not isolation. #}
{% set last_seam_x = (first_divider_x | default(143)) + 12 + (metrics | length | default(1)) * metric_pitch %}
{% set status_x = (last_seam_x + width) // 2 %}
{% set status_cy = strip_h // 2 %}
<g data-hw-zone="status" transform="translate({{ status_x }},{{ status_cy }})"
   {% if status_shape_rendering != "geometricPrecision" %}shape-rendering="{{ status_shape_rendering }}"{% endif %}>
{% include "frames/strip/" ~ paradigm_strip ~ "-status.j2" %}
</g>

{# ── Border motion SMIL overlay (shared across all paradigms) ── #}
{% if motion_border_defs | default('') %}
<defs>{{ motion_border_defs | safe }}</defs>
{% endif %}
{% if motion_border_overlay | default('') %}
{{ motion_border_overlay | safe }}
{% endif %}
{% endblock %}
