{# Cellular stats card v4b — compact 530×233 with three vertical zones.

   Replaces the v0.3.0-Round-9 5-slot vertical stack (header / hero /
   secondary / heatmap / language) with three zones:

     1. HEADER BAND (y=0..39) — gradient-filled rect with username + bio inline,
        HYPERWEAVE brand stamp top-right, accent hairline at y=39
     2. METRIC STRIP (y≈73) — single-row hierarchy: hero (mvh, 26px white),
        medium (mvm, 20px gray), small (mvs, 15px gray), streak (mvg, 15px
        green). Five values: STARS · COMMITS · PRS · CONTRIB · STREAK
     3. HEATMAP + LEGEND + LANGUAGE (y=101..221) — year label + 5-tier legend
        column at top, 7×42 square heatmap below, 5-segment language bar
        with inline labels at the bottom

   The card outline (rounded rect at info_accent @ 10% alpha) frames the
   composition. Heatmap level 0..4 maps to area_tiers[4..0] (darkest →
   brightest); active levels carry b1/b2/b3/b4 phase-staggered breathe. #}

{% set sw = width | default(530) %}
{% set sh = height | default(233) %}
{% set _surface = surface_0 | default('#0A0A0A') %}
{% set area_tiers = cellular_palette.primary.area_tiers %}
{% set _accent = stats_info_accent %}
{% set _band_h = stats_header_band_height | default(39) %}

{# Card clip — masks rendering to the rounded rect so the breathing heatmap
   and language bar can't bleed past the corners. #}
<g clip-path="url(#{{ uid }}-card-clip)">

{# Void ground — full canvas. #}
<rect width="{{ sw }}" height="{{ sh }}" fill="{{ _surface }}"/>

{# ZONE 1: HEADER BAND (y=0..39) — gradient fill, username + bio inline at
   y=24, HYPERWEAVE brand stamp top-right, accent hairline at y=39. #}
<rect width="{{ sw }}" height="{{ _band_h }}" fill="url(#{{ uid }}-top-grad)"/>
<line x1="0" y1="{{ _band_h }}" x2="{{ sw }}" y2="{{ _band_h }}" stroke="{{ _accent }}" stroke-opacity="0.10" stroke-width="1"/>
<text x="20" y="24" class="{{ uid }}-username">{{ stats_username | upper }}</text>
{% if stats_bio or stats_repo_label %}
<text x="98" y="24" class="{{ uid }}-bio">{% if stats_repo_label %}{{ stats_repo_label }}{% endif %}{% if stats_repo_label and stats_bio %} · {% endif %}{% if stats_bio %}{{ stats_bio }}{% endif %}</text>
{% endif %}
<text x="{{ sw - 20 }}" y="22" class="{{ uid }}-brand" text-anchor="end">HYPERWEAVE</text>

{# ZONE 2: METRIC STRIP (y≈73) — single-row hierarchy. Layout from the v4b
   prototype: STARS hero anchored at x=20; COMMITS medium follows; PRS and
   CONTRIB small; STREAK green right-aligned at x≈459. The strip is one
   visual rhythm; values snap to a 73-baseline so digit baselines align even
   though font sizes differ.

   Slot positions are absolute (computed from prototype) rather than flex —
   Jinja2 doesn't resolve text widths at template time, so a flex layout
   would require post-render measurement. The compositor knows the exact
   pixel positions because metric values are formatted to fit the column
   budget by the resolver (textLength caps if a value would overflow). #}
<text x="20"  y="72.8" class="{{ uid }}-mvh">{{ stars_display | default('--') }}</text>
<text x="89.5"  y="72.8" class="{{ uid }}-mlb">STARS</text>
<text x="135" y="72.8" class="{{ uid }}-mvm">{{ commits_display | default('--') }}</text>
<text x="173" y="72.8" class="{{ uid }}-mlb">COMMITS</text>
<text x="229" y="72.8" class="{{ uid }}-mvs">{{ prs_display | default('--') }}</text>
<text x="241" y="72.8" class="{{ uid }}-mlb">PRS</text>
<text x="276" y="72.8" class="{{ uid }}-mvs">{{ contrib_display | default('--') }}</text>
<text x="305" y="72.8" class="{{ uid }}-mlb">CONTRIB</text>
<text x="459" y="72.8" class="{{ uid }}-mvg">{{ streak_display | default('--') }}</text>
<text x="479" y="72.8" class="{{ uid }}-mlb">STREAK</text>

{# ZONE 3a: YEAR LABEL + LEGEND COLUMN (y=101..108).
   Year (e.g. "2026") at left x=20; 5-tier legend rects at right side
   showing the heatmap palette in tier order (empty→brightest). Cell positions
   match prototype literals: x=467/476/485/494/503. #}
<text x="20" y="106.6" class="{{ uid }}-cyr">{{ stats_heatmap_year }}</text>
{% set _legend_x = [467, 476, 485, 494, 503] %}
{% for i in range(5) %}
<rect x="{{ _legend_x[i] }}" y="101" width="7" height="7" rx="1.5" fill="{{ area_tiers[4 - i] }}"/>
{% endfor %}

{# ZONE 3b: HEATMAP (y=114..198) — 7 rows × 42 cols of square 11.080px cells
   with 1.2px gap (stride 12.28). Cells start at x=20 and end at
   x=20 + 41*12.28 + 11.08 = 514.56. Height fills 84.76px (7×11.080 +
   6×1.2). Active cells (level >= 1) carry b1/b2/b3/b4 phase-staggered
   breathe; level-0 cells stay static at the darkest tier (area_tiers[4]). #}
{% set _hm_rows = heatmap_rows | default(7) %}
{% set _hm_cols = heatmap_cols | default(42) %}
{% set _hm_cell = heatmap_cell_size | default(11.080) %}
{% set _hm_gap = heatmap_cell_gap | default(1.2) %}
{% set _hm_stride = _hm_cell + _hm_gap %}
{% set _hm_x0 = 20 %}
{% set _hm_y0 = 114 %}
<g data-hw-zone="heatmap">
  {% set grid = heatmap_grid | default([]) %}
  {% set grid_len = grid | length %}
  {% set window_cells = _hm_cols * _hm_rows %}
  {% set offset = (grid_len - window_cells) if grid_len > window_cells else 0 %}
  {% set _anim_classes = ["b1", "b2", "b3", "b4"] %}
  {% for col in range(_hm_cols) %}
    {% for row in range(_hm_rows) %}
      {% set idx = offset + col * _hm_rows + row %}
      {% if idx >= 0 and idx < grid_len %}
        {% set cell = grid[idx] %}
        {% set level = cell.level | default(0) if cell is mapping else 0 %}
      {% else %}
        {% set level = 0 %}
      {% endif %}
      {% if level < 0 %}{% set level = 0 %}{% endif %}
      {% if level > 4 %}{% set level = 4 %}{% endif %}
      {% set fill = area_tiers[4 - level] %}
      {% set cx = _hm_x0 + col * _hm_stride %}
      {% set cy = _hm_y0 + row * _hm_stride %}
      {% if level >= 1 %}
      <rect x="{{ '%.3f' % cx }}" y="{{ '%.3f' % cy }}" width="{{ _hm_cell }}" height="{{ _hm_cell }}" rx="1.5" fill="{{ fill }}" class="{{ _anim_classes[(col + row) % 4] }}"/>
      {% else %}
      <rect x="{{ '%.3f' % cx }}" y="{{ '%.3f' % cy }}" width="{{ _hm_cell }}" height="{{ _hm_cell }}" rx="1.5" fill="{{ fill }}"/>
      {% endif %}
    {% endfor %}
  {% endfor %}
</g>

{# ZONE 3c: LANGUAGE FOOTER — inline swatch + label pairs at y=217.

   v0.3.0 polish replaces the proportional bar with a single row of
   "swatch label pct%" entries spread across the heatmap's content zone.
   The bar communicated nothing the swatches don't already convey (segment
   colors equal swatch colors), and squeezed labels into ~132px causing
   right-edge overflow on long names like "Jupyter Notebook".

   Layout positions are computed by the resolver via measure_text against
   JBM 7px so each label's pixel width is known precisely. Languages are
   pre-sorted by descending pct; if all four don't fit in the available
   zone, the resolver drops from the end (lowest pct first). Full canonical
   names are preserved — no aliasing, no truncation.

   Swatches use the same area_tiers cycle the bar segments used so the
   chromatic identity carries through the redesign unchanged. The .lt
   class (mid_accent at opacity 0.6) keeps labels quiet — the heatmap
   above remains the visual focus of the bottom half of the card. #}
<g data-hw-zone="languages">
  {% for entry in language_layout | default([]) %}
  <rect x="{{ entry.swatch_x }}" y="216" width="5" height="5" rx="1" fill="{{ entry.swatch_color }}"/>
  <text x="{{ entry.label_x }}" y="221" class="{{ uid }}-lt">{{ entry.label_text }}</text>
  {% endfor %}
</g>

</g>{# end card-clip #}

{# Card outline — drawn OUTSIDE the clip so the rounded rect stroke isn't
   itself clipped. info_accent at 10% alpha frames the composition without
   competing with the heatmap. #}
<rect x="0.5" y="0.5" width="{{ sw - 1 }}" height="{{ sh - 1 }}" rx="8" fill="none" stroke="{{ _accent }}" stroke-opacity="0.10" stroke-width="1"/>
