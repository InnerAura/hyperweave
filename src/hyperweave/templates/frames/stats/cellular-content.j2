{# Cellular stats card — 495x260 soulcard, bifamily substrate + 5-slot vertical.

   Spec: cellular-automata-stat-card.svg. Layout:
     Substrate: 22px cells × 3 cols × 12 rows per flank (teal left, amethyst right)
     Data panel: x=66 w=363 y=6 h=248
     HEADER slot   (y 12-44): username (Orbitron 11px #1E849A) + bio (JBM 7.5px)
     HERO slot     (y 52-106): 2-column Chakra Petch 38px — stars + commits
     SECONDARY slot (y 116-162): 4-column Chakra Petch 26px — PRS / ISSUES / CONTRIB / STREAK
     HEATMAP slot  (y 172-224): 7×42 GitHub-style contribution grid, palette #161b22/#0e4429/#006d32/#26a641/#39d353
     FOOTER slot   (y 228-250): small meta text #}

{% set sw = width | default(495) %}
{% set sh = height | default(260) %}
{% set cell_size = 22 %}
{% set flank_cols = 3 %}
{% set flank_w = flank_cols * cell_size %}
{% set n_rows = (sh + cell_size - 1) // cell_size %}
{% set panel_x = flank_w %}
{% set panel_w = sw - 2 * flank_w %}

{# Void ground #}
<rect width="{{ sw }}" height="{{ sh }}" fill="{{ surface_0 | default('#04060A') }}"/>

{# Left teal flank #}
{% set blue_trio = variant_blue_pattern_cells %}
{% set blue_classes = ["cs1", "cs2", "csd", "cs3", "cs4", "csf", "csd", "cs2", "cs1", "cs4", "cs3", "csf"] %}
<g opacity="0.65">
{% for col in range(flank_cols) %}
  {% for row in range(n_rows) %}
  {% set cidx = (col + row) % 3 %}
  {% set clsidx = (col * n_rows + row) % 12 %}
  <rect x="{{ col * cell_size }}" y="{{ row * cell_size }}" width="{{ cell_size }}" height="{{ cell_size }}" fill="{{ blue_trio[cidx] }}" class="{{ blue_classes[clsidx] }}"/>
  {% endfor %}
{% endfor %}
</g>

{# Right amethyst flank #}
{% set purple_trio = variant_purple_pattern_cells %}
{% set purple_classes = ["cs2", "csd", "csf", "cs3", "cs1", "cs4", "csd", "cs2", "csf", "cs3", "cs1", "csd"] %}
<g opacity="0.65">
{% for col in range(flank_cols) %}
  {% for row in range(n_rows) %}
  {% set cidx = (col + row) % 3 %}
  {% set clsidx = (col * n_rows + row) % 12 %}
  <rect x="{{ sw - flank_w + col * cell_size }}" y="{{ row * cell_size }}" width="{{ cell_size }}" height="{{ cell_size }}" fill="{{ purple_trio[cidx] }}" class="{{ purple_classes[clsidx] }}"/>
  {% endfor %}
{% endfor %}
</g>

{# Data panel #}
<rect x="{{ panel_x }}" y="6" width="{{ panel_w }}" height="{{ sh - 12 }}" fill="{{ surface_0 | default('#04060A') }}" opacity="0.92"/>
<rect x="{{ panel_x }}" y="6" width="{{ panel_w }}" height="{{ sh - 12 }}" fill="none" stroke="{{ variant_blue_pattern_cells[0] | default('#1E849A') }}" stroke-width="0.5" opacity="0.25"/>

{# Slot-boundary separators — production draws a 0.3-stroke hairline between
   each vertical band (header/hero/secondary/heatmap/footer). These are the
   visual rhythm ticks the soulcard lays out against; omitting them collapses
   the 5-slot architecture into undifferentiated content. Line bounds:
   x1 = panel_x + 16 (= 82), x2 = panel_x + panel_w - 16 (= 413). #}
{% set sep_left = panel_x + 16 %}
{% set sep_right = panel_x + panel_w - 16 %}
{% set sep_stroke = variant_blue_pattern_cells[0] | default('#1E849A') %}

{# SLOT 1: HEADER (y 12-44) — username + bio + accent underline.
   All <text> elements use CSS classes from cellular-defs.j2 so the
   custom fonts (Orbitron) actually load. Inline font-family attributes
   on <text> are overridden by the catch-all `text{font-family:'JBM'}`
   rule per CSS specificity rules. #}
<g data-hw-zone="header">
  <text x="{{ panel_x + 16 }}" y="26" class="{{ uid }}-username">{{ stats_username | upper }}</text>
  <text x="{{ panel_x + 16 }}" y="42" class="{{ uid }}-bio">{{ stats_repo_label | default('') }}{% if stats_bio %} · {{ stats_bio }}{% endif %}</text>
  <rect x="{{ panel_x + 16 }}" y="48" width="40" height="1.5" fill="{{ sep_stroke }}" opacity="0.5"/>
  <text x="{{ panel_x + panel_w - 16 }}" y="23" class="{{ uid }}-brand" text-anchor="end">HYPERWEAVE</text>
</g>
<line x1="{{ sep_left }}" y1="52" x2="{{ sep_right }}" y2="52" stroke="{{ sep_stroke }}" stroke-width="0.3" opacity="0.15"/>

{# SLOT 2: HERO (y 52-106) — 2-column primary metrics. STARS left, COMMITS right.
   Spec includes a delta indicator (▲ 2,431 /yr) next to STARS in green — emitted
   conditionally when stars_delta_display is non-empty. #}
{% set hero_left_x = panel_x + 16 %}
{% set hero_right_x = panel_x + 191 %}
<g data-hw-zone="hero">
  <text x="{{ hero_left_x }}" y="92" class="{{ uid }}-hero-value">{{ stars_display | default('--') }}</text>
  <text x="{{ hero_right_x }}" y="92" class="{{ uid }}-hero-value-alt">{{ commits_display | default('--') }}</text>
  <text x="{{ hero_left_x }}" y="108" class="{{ uid }}-hero-label">STARS</text>
  {% if stars_delta_display %}
  <text x="{{ hero_left_x + 50 }}" y="108" class="{{ uid }}-hero-delta">▲ {{ stars_delta_display }}</text>
  {% endif %}
  <text x="{{ hero_right_x }}" y="108" class="{{ uid }}-hero-label">COMMITS</text>
</g>
<line x1="{{ sep_left }}" y1="116" x2="{{ sep_right }}" y2="116" stroke="{{ sep_stroke }}" stroke-width="0.3" opacity="0.12"/>

{# SLOT 3: SECONDARY (y 116-162) — 4-column metrics: PRS / ISSUES / CONTRIB / STREAK.
   Value tints: PRS/ISSUES muted slate (#808898), CONTRIB dimmer (#606878), STREAK green (#22c55e).
   Label tint source: `variant_purple_pattern_cells[0]` gives the "furniture"
   purple (#6B3B8A). Using `variant_purple_seam_mid` here resolves to #A88AD4
   (the "pennant" tone), which is a role mismatch per the two-stop chromatic
   rule — labels are low-hierarchy chrome, not state signal. STREAK label
   stays on the teal seam because STREAK is the active-pulse indicator. #}
{% set purple_label = variant_purple_pattern_cells[0] | default('#6B3B8A') %}
{% set teal_label = variant_blue_pattern_cells[0] | default('#1E849A') %}
{% set sec_cols = [
  (16, prs_display | default('--'), 'PRS', '#808898', purple_label),
  (96, issues_display | default('--'), 'ISSUES', '#808898', purple_label),
  (176, contrib_display | default('--'), 'CONTRIB', '#606878', purple_label),
  (271, streak_display | default('--'), 'STREAK', '#22c55e', teal_label)
] %}
<g data-hw-zone="secondary">
{% for col in sec_cols %}
  <text x="{{ panel_x + col[0] }}" y="146" class="{{ uid }}-sec-value" fill="{{ col[3] }}">{{ col[1] }}</text>
  <text x="{{ panel_x + col[0] }}" y="162" class="{{ uid }}-sec-label" fill="{{ col[4] }}">{{ col[2] }}</text>
{% endfor %}
</g>
<line x1="{{ sep_left }}" y1="172" x2="{{ sep_right }}" y2="172" stroke="{{ sep_stroke }}" stroke-width="0.3" opacity="0.12"/>

{# SLOT 4: HEATMAP (y 172-224) — 4 rows x 42 cols of 5x5 cells with 2px gap.
   Prototype metadata: "Chose 4-row heatmap over full 7-row GitHub graph to
   fit 260px height". 4 rows × 7 row-pitch = 28px tall, leaving room for a
   roomier label header above and a footer gutter below.

   Layout: label and heatmap SHARE the same left edge at x=panel_x+16=82.
   The prototype offset the heatmap 30px to the right of the label, which
   the user explicitly flagged as a misalignment bug — fixing it BETTER
   than the prototype is the explicit goal. 42 cols × 7px stride = 294px
   span, ending at x=376. Right gutter to panel edge (x=429) is 53px,
   well within the panel's 16px-min margin discipline.

   Label class `-heatmap-label` lives in cellular-defs.j2 — JBM 6px in
   teal at 60% opacity so the header reads as quiet metadata, not a
   competing slot title. CSS class wins over the catch-all `text{}` rule.

   Window: last 42 weeks × 4 rows = 168 cells from the tail of the
   chronological grid; earlier weeks truncated. Year suffix is the
   current calendar year so the label stays truthful. #}
{% set heatmap_year = (stats_heatmap_year | default("") | string) %}
<text data-hw-zone="heatmap-label" x="{{ panel_x + 16 }}" y="185" class="{{ uid }}-heatmap-label">CONTRIBUTIONS{% if heatmap_year %} {{ heatmap_year }}{% endif %}</text>
<g data-hw-zone="heatmap" transform="translate({{ panel_x + 16 }}, 190)">
  {% set heatmap_palette = ['#161b22', '#0e4429', '#006d32', '#26a641', '#39d353'] %}
  {% set grid = heatmap_grid | default([]) %}
  {# Window the last 42 weeks × 4 rows (168 cells) from the tail of the
     chronological grid. Stride is column*7+row to mirror GitHub's calendar
     layout (Sun-Sat columns, weeks across); we render rows 3-6 (Wed-Sat)
     for the densest activity stripe. #}
  {% set cols = 42 %}
  {% set rows = 4 %}
  {% set window_cells = cols * 7 %}
  {% set grid_len = grid | length %}
  {% set offset = (grid_len - window_cells) if grid_len > window_cells else 0 %}
  {% set row_skip = 3 %}
  {% for row in range(rows) %}
    <g transform="translate(0,{{ row * 7 }})">
    {% for col in range(cols) %}
      {% set idx = offset + col * 7 + (row + row_skip) %}
      {% if idx >= 0 and idx < grid_len %}
        {% set cell = grid[idx] %}
        {% set level = cell.level | default(0) if cell is mapping else 0 %}
      {% else %}
        {% set level = 0 %}
      {% endif %}
      {% if level < 0 %}{% set level = 0 %}{% endif %}
      {% if level > 4 %}{% set level = 4 %}{% endif %}
      <rect x="{{ col * 7 }}" y="0" width="5" height="5" rx="0.5" fill="{{ heatmap_palette[level] }}"/>
    {% endfor %}
    </g>
  {% endfor %}
</g>
<line x1="{{ sep_left }}" y1="228" x2="{{ sep_right }}" y2="228" stroke="{{ sep_stroke }}" stroke-width="0.3" opacity="0.12"/>

{# SLOT 5: FOOTER / LANGUAGE BAR — stacked track with inline-tspan legend.
   Production architecture at translate(panel_x+16, 236):
     • track:   331×3 fill=#0a0e14 rx=1  (dark gutter under the segments)
     • segs:    stacked with a 2px gap between each; widths map 1:1 from pct
                (rounded) onto the 331px track so Σ(seg_w) ≤ track_w - gaps.
     • legend:  single <text y=14> with tspans, each prefixed by a coloured
                "■" so the chromatic legend doubles as the palette key.
   The gap is the chromatic delimiter — it's what lets the eye count four
   segments rather than reading one continuous bar.

   Palette uses two-stop chromatic hierarchy per the genome rule: teal
   furniture (#1E849A) and seam-mid (#104052) for info/substrate; purple
   furniture (#6B3B8A) and seam-mid (#160B24) for the alternation. The
   cycle is teal-bright / purple-bright / teal-muted / purple-muted so
   adjacent languages never share the same hue. #}
{% set _bar_x = panel_x + 16 %}
{% set _bar_w = panel_w - 32 %}
{% set _bar_y = 236 %}
{% set _gap = 2 %}
{% set _lang_cycle = [
  (variant_blue_pattern_cells[0] | default('#1E849A'), 0.6),
  (variant_purple_pattern_cells[0] | default('#6B3B8A'), 0.5),
  (variant_blue_pattern_cells[1] | default('#104052'), 0.4),
  (variant_purple_pattern_cells[2] | default('#160B24'), 0.3)
] %}
<g data-hw-zone="languages" transform="translate({{ _bar_x }},{{ _bar_y }})">
  <rect width="{{ _bar_w }}" height="3" rx="1" fill="#0a0e14"/>
  {% set _total_pct = namespace(sum=0) %}
  {% for lang in languages | default([]) %}{% set _total_pct.sum = _total_pct.sum + (lang.pct | default(0)) %}{% endfor %}
  {# Allocate (len - 1) gaps from the track width; remaining px is the
     drawable segment budget. #}
  {% set _n = (languages | default([])) | length %}
  {% set _drawable = _bar_w - (_gap * ([_n - 1, 0] | max)) %}
  {% set _running = namespace(x=0) %}
  {% for lang in languages | default([]) %}
    {% set _pct = lang.pct | default(0) %}
    {% set _seg_w = ((_drawable * _pct / _total_pct.sum) | round(0, 'floor') | int) if _total_pct.sum > 0 else 0 %}
    {% set _color = _lang_cycle[loop.index0 % 4][0] %}
    {% set _op = _lang_cycle[loop.index0 % 4][1] %}
    {% if _seg_w > 0 %}
    <rect x="{{ _running.x }}" y="0" width="{{ _seg_w }}" height="3" {% if loop.first %}rx="1"{% endif %} fill="{{ _color }}" opacity="{{ _op }}"/>
    {% endif %}
    {% set _running.x = _running.x + _seg_w + _gap %}
  {% endfor %}
  <text y="14" class="{{ uid }}-lang-text">
  {% for lang in languages | default([]) %}
    {% set _name = lang.name | default('') %}
    {% set _pct = lang.pct | default(0) %}
    {% set _color = _lang_cycle[loop.index0 % 4][0] %}
    {% set _op = _lang_cycle[loop.index0 % 4][1] + 0.1 %}
    <tspan {% if not loop.first %}dx="3" {% endif %}fill="{{ _color }}" opacity="{{ _op }}">■</tspan> {{ _name }}{% if _name %} {% endif %}{{ _pct | int }}
  {% endfor %}
  </text>
</g>
