{# Primer BADGE — light substrate (v04alpha1). Two-zone editorial badge: a label
   zone (brand glyph + Inter category label — secondary branding) and a recessed
   value zone (animated state mark + Inter value word), split by a carved 3-layer
   seam, with a convex bevel + hairline rim. No top gloss band and no drop shadow
   on light — the white ground carries itself; the bevel + rim give the edge.
   Everything rides inside the rounded clip. Geometry from compose/layout.py +
   resolver; zero arithmetic. #}
<g clip-path="url(#{{ uid }}-clip)">
  <rect width="{{ width }}" height="{{ height }}" fill="url(#{{ uid }}-bg)"/>
  <rect x="{{ badge_vzone.x }}" y="{{ badge_vzone.y }}" width="{{ badge_vzone.w }}" height="{{ badge_vzone.h }}" fill="url(#{{ uid }}-vz)"/>
  {# Carved seam: faint edge + ink recess core + bright highlight. #}
  <rect x="{{ badge_seam_carved.edge_x }}" y="{{ badge_seam_carved.y }}" width="{{ badge_seam_carved.edge_w }}" height="{{ badge_seam_carved.h }}" fill="url(#{{ uid }}-sm0)"/>
  <rect x="{{ badge_seam_carved.recess_x }}" y="{{ badge_seam_carved.y }}" width="{{ badge_seam_carved.recess_w }}" height="{{ badge_seam_carved.h }}" fill="url(#{{ uid }}-sm1)"/>
  <rect x="{{ badge_seam_carved.shine_x }}" y="{{ badge_seam_carved.y }}" width="{{ badge_seam_carved.shine_w }}" height="{{ badge_seam_carved.h }}" fill="url(#{{ uid }}-sm2)"/>

  {% if has_glyph and glyph_svg %}
  <g data-hw-zone="glyph" transform="translate({{ glyph_x }},{{ glyph_y }})">
    {{ glyph_svg | safe }}
  </g>
  {% endif %}

  <text data-hw-zone="label"
        x="{{ label_x }}" y="{{ badge_label_text_y }}"
        text-anchor="middle"
        font-family="var(--dna-font-display, 'Inter', system-ui, sans-serif)"
        font-size="{{ badge_label_font_size }}" font-weight="{{ badge_label_font_weight }}"
        fill="{{ _genome_raw.ink }}"
        letter-spacing="{{ badge_label_letter_spacing_em }}em"{% if label_text_length and label_text_length > 0 %} textLength="{{ label_text_length }}" lengthAdjust="spacingAndGlyphs"{% endif %}>{{ label_display | default(label | upper) }}</text>

  {# Per-state animated status mark — include-dispatched by indicator_shape
     (primer: status-glyph), sub-dispatched by status_glyph_state. Leads the value
     word as a status pill [mark] value. Geometry + center from the layout engine. #}
  {% if show_indicator %}
  {% include "frames/badge/indicators/" ~ indicator_shape ~ "-indicator.j2" %}
  {% endif %}

  <text data-hw-zone="value"
        x="{{ value_x }}" y="{{ text_y }}"
        text-anchor="middle"
        font-family="var(--dna-font-display, 'Inter', system-ui, sans-serif)"
        font-size="{{ badge_value_font_size }}" font-weight="{{ badge_value_font_weight }}"
        fill="{{ badge_value_color }}"
        letter-spacing="{{ badge_value_letter_spacing_em }}em"{% if value_text_length and value_text_length > 0 %} textLength="{{ value_text_length }}" lengthAdjust="spacingAndGlyphs"{% endif %}>{{ value }}</text>

  {# Convex bevel + hairline rim (double stroke). #}
  <rect x="{{ badge_bevel.x }}" y="{{ badge_bevel.y }}" width="{{ badge_bevel.w }}" height="{{ badge_bevel.h }}" rx="{{ badge_bevel.rx }}" fill="none" stroke="url(#{{ uid }}-bevel)" stroke-width="1"/>
  <rect x="{{ light_perimeter_inset }}" y="{{ light_perimeter_inset }}" width="{{ light_perimeter_w }}" height="{{ light_perimeter_h }}" rx="{{ badge_stroke_rx }}" fill="none" stroke="{{ _genome_raw.stroke }}" stroke-width="0.5"/>
</g>
