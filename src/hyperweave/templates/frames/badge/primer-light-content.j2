{# Primer BADGE — light substrate (v04alpha2). Two-plate badge with the
   "white-on-white" seam: the label plate is tinted by a whisper of ink (0.03)
   and the seam is an ink groove (0.09) + a strong white shine (0.85), so the
   split reads as a pressed crease in the white ground rather than a drawn
   rule. An inner white highlight + 1px border carry the edge — no drop
   shadow: the viewBox would clip it to corner-notch smudges outside the rx4
   edge. Geometry from compose/layout.py + resolver; zero arithmetic. #}
<g clip-path="url(#{{ uid }}-clip)">
  <rect width="{{ width }}" height="{{ height }}" fill="url(#{{ uid }}-bg)"/>
  {# Label-plate tint + paired groove/shine seam — ink-derived on light. #}
  <rect x="{{ badge_label_zone.x }}" y="{{ badge_label_zone.y }}" width="{{ badge_label_zone.w }}" height="{{ badge_label_zone.h }}" fill="rgba({{ ink_rgb }},0.03)"/>
  <rect x="{{ badge_seam_pair.groove_x }}" y="{{ badge_seam_pair.y }}" width="{{ badge_seam_pair.w }}" height="{{ badge_seam_pair.h }}" fill="rgba({{ ink_rgb }},0.09)"/>
  <rect x="{{ badge_seam_pair.shine_x }}" y="{{ badge_seam_pair.y }}" width="{{ badge_seam_pair.w }}" height="{{ badge_seam_pair.h }}" fill="rgba(255,255,255,0.85)"/>

  {% if has_glyph and glyph_svg %}
  <g data-hw-zone="glyph" transform="translate({{ glyph_x }},{{ glyph_y }})">
    {{ glyph_svg | safe }}
  </g>
  {% endif %}

  {# Mono label — muted ink_secondary voice; the glyph is the sole accent.
     No textLength: mono advance is exact (exact-rail paradigm). #}
  <text data-hw-zone="label"
        x="{{ label_x }}" y="{{ badge_label_text_y }}"
        text-anchor="middle"
        font-family="var(--dna-font-mono, 'JetBrains Mono', ui-monospace, monospace)"
        font-size="{{ badge_label_font_size }}" font-weight="{{ badge_label_font_weight }}"
        fill="{{ _genome_raw.ink_secondary }}"
        letter-spacing="{{ badge_label_letter_spacing_em }}em">{{ label_display | default(label | upper) }}</text>

  {# Per-state animated status mark — include-dispatched by indicator_shape
     (primer: status-glyph), sub-dispatched by status_glyph_state. Leads the
     value word as a status pill [mark] value. #}
  {% if show_indicator %}
  {% include "frames/badge/indicators/" ~ indicator_shape ~ "-indicator.j2" %}
  {% endif %}

  {# Mono value — neutral ink (a metric is data, not status); state-colored
     only on stateful badges via badge_value_color. #}
  <text data-hw-zone="value"
        x="{{ value_x }}" y="{{ text_y }}"
        text-anchor="middle"
        font-family="var(--dna-font-mono, 'JetBrains Mono', ui-monospace, monospace)"
        font-size="{{ badge_value_font_size }}" font-weight="{{ badge_value_font_weight }}"
        fill="{{ badge_value_color }}">{{ value }}</text>
</g>
{# Inner white highlight + 1px border (double-stroke rim). #}
<rect x="{{ badge_inner_highlight.x }}" y="{{ badge_inner_highlight.y }}" width="{{ badge_inner_highlight.w }}" height="{{ badge_inner_highlight.h }}" rx="{{ badge_inner_highlight.rx }}" fill="none" stroke="rgba(255,255,255,0.55)" stroke-width="{{ badge_inner_highlight.stroke_w }}"/>
<rect x="{{ badge_outer_border.x }}" y="{{ badge_outer_border.y }}" width="{{ badge_outer_border.w }}" height="{{ badge_outer_border.h }}" rx="{{ badge_outer_border.rx }}" fill="none" stroke="{{ _genome_raw.stroke }}" stroke-width="{{ badge_outer_border.stroke_w }}"/>
