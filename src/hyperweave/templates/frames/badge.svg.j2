{# HyperWeave Badge Frame — Profile-dispatched.
   Templates never check genome identity. Data presence drives rendering:
     envelope_stops present  → chrome defs/content
     envelope_stops absent   → brutalist defs/content
   Specimens: badge-final.svg (chrome), badge_*.svg (brutalist).
   Extends document.svg.j2. #}
{% extends "document.svg.j2" %}

{% block defs %}
{% if envelope_stops | default([]) %}
{% include "frames/badge/chrome-defs.j2" %}
{% else %}
{% include "frames/badge/brutalist-defs.j2" %}
{% endif %}
{% endblock %}

{% block content %}
{% set h = height | default(20) %}
{% set accent_w = accent_bar_width | default(4) %}
{% set sep_w_val = sep_width | default(2) %}
{% set seam_w_val = seam_width | default(3) %}
{% set ind_size = indicator_size | default(8) %}
{% set lp_w = left_panel_width | default(60) %}

{% if envelope_stops | default([]) %}
{% include "frames/badge/chrome-content.j2" %}
{% else %}
{% include "frames/badge/brutalist-content.j2" %}
{% endif %}

{# Border motion SMIL overlay (shared across all profiles) #}
{% if motion_border_defs | default('') %}
<defs>{{ motion_border_defs | safe }}</defs>
{% endif %}
{% if motion_border_overlay | default('') %}
{{ motion_border_overlay | safe }}
{% endif %}
{% endblock %}
