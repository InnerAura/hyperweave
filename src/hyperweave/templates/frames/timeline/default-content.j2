{# Timeline paradigm: default.

   Vertical node chain with opacity cascade into the future. Each node is a
   rect/circle/diamond (from genome.structural.data_point_shape) sitting on
   the spine at its computed y, plus a title + subtitle + date label in the
   right gutter. #}

{% set node_cx = timeline_node_cx | default(80) %}
{% set text_x = node_cx + 40 %}

{% for item in timeline_items %}
<g data-hw-zone="timeline-node-{{ item.index }}" opacity="{{ item.opacity }}">
  {# Node shape dispatch — pre-resolved by the resolver. #}
  {% if item.node_shape == "circle" %}
    <circle cx="{{ node_cx }}" cy="{{ item.y }}" r="9" fill="{{ item.node_fill }}" stroke="var(--dna-surface)" stroke-width="2"/>
  {% elif item.node_shape == "diamond" %}
    <rect x="{{ node_cx - 9 }}" y="{{ item.y - 9 }}" width="18" height="18" fill="{{ item.node_fill }}" stroke="var(--dna-surface)" stroke-width="2" transform="rotate(45 {{ node_cx }} {{ item.y }})"/>
  {% else %}
    <rect x="{{ node_cx - 9 }}" y="{{ item.y - 9 }}" width="18" height="18" fill="{{ item.node_fill }}" stroke="var(--dna-surface)" stroke-width="2"/>
  {% endif %}

  {# Title + subtitle + date in the right gutter #}
  <text x="{{ text_x }}" y="{{ item.y - 6 }}" class="hw-timeline-node-title" font-size="22" fill="var(--dna-ink-primary)">{{ item.title }}</text>
  {% if item.subtitle %}
  <text x="{{ text_x }}" y="{{ item.y + 14 }}" class="hw-timeline-node-sub" font-size="9" fill="var(--dna-ink-muted)">{{ item.subtitle | upper }}</text>
  {% endif %}
  {% if item.date %}
  <text x="{{ (width | default(800)) - 20 }}" y="{{ item.y - 2 }}" class="hw-timeline-date" font-size="9" fill="var(--dna-signal)" text-anchor="end" letter-spacing="0.15em">{{ item.date }}</text>
  {% endif %}

  {# Status indicator dot next to the date #}
  <rect x="{{ (width | default(800)) - 36 }}" y="{{ item.y + 2 }}" width="6" height="6" fill="{{ item.node_fill }}"/>
</g>
{% endfor %}
