{# HyperWeave Horizontal Marquee — 800x40 LIVE ticker.
   Profile-dispatched: data presence drives rendering, not profile identity.
     envelope_stops present  -> chrome defs/content
     envelope_stops absent   -> brutalist defs/content
   Structure: LIVE label block (left) -> divider -> clip-masked scroll -> edge fades.
   Specimens: chrome-horizon-marquees-v2 (chrome), brutalist-emerald-marquees-v5 (brutalist).
   Extends document.svg.j2.  Context: ComposeSpec dict. #}
{% extends "document.svg.j2" %}

{% block defs %}
{% set mw = width | default(800) %}
{% set mh = height | default(40) %}
{% set lp_w = label_panel_width | default(130) %}
{% set cx = clip_x | default(132) %}
  {# LIVE block gradient — resolved hex (var() unreliable inside <stop>) #}
  <linearGradient id="{{ uid }}-accent" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0%" stop-color="{{ signal_hex | default('#10B981') }}" stop-opacity="0.95"/>
    <stop offset="100%" stop-color="{{ signal_hex | default('#10B981') }}" stop-opacity="0.65"/>
  </linearGradient>
  {# Scroll clip — parametric via clip_inset_y / clip_inset_x #}
  <clipPath id="{{ uid }}-scroll-clip">
    <rect x="{{ cx }}" y="{{ clip_inset_y | default(4) }}" width="{{ mw - cx - (clip_inset_x | default(4)) }}" height="{{ mh - (clip_inset_y | default(4)) * 2 }}"/>
  </clipPath>
  {# Edge fades #}
  <linearGradient id="{{ uid }}-fade-l" x1="0" y1="0" x2="1" y2="0">
    <stop offset="0%" stop-color="{{ surface_hex | default('#0A0A0A') }}" stop-opacity="1"/>
    <stop offset="100%" stop-color="{{ surface_hex | default('#0A0A0A') }}" stop-opacity="0"/>
  </linearGradient>
  <linearGradient id="{{ uid }}-fade-r" x1="0" y1="0" x2="1" y2="0">
    <stop offset="0%" stop-color="{{ surface_hex | default('#0A0A0A') }}" stop-opacity="0"/>
    <stop offset="100%" stop-color="{{ surface_hex | default('#0A0A0A') }}" stop-opacity="1"/>
  </linearGradient>
{% if envelope_stops | default([]) %}
{% include "frames/marquee-horizontal/chrome-defs.j2" %}
{% else %}
{% include "frames/marquee-horizontal/brutalist-defs.j2" %}
{% endif %}
{% endblock %}

{% block content %}
{% set mw = width | default(800) %}
{% set mh = height | default(40) %}
{% set lp_w = label_panel_width | default(130) %}
{% set cx = clip_x | default(132) %}
{% set sd = scroll_distance | default(1000) %}
{% set dur = scroll_dur | default(11.09) %}
{% set fw = fade_width | default(24) %}
{% set dx = item_dx | default(20) %}
{% set start_x = item_start_x | default(148) %}

{# ══════════════════════════════════════════════════════════════════
   FRAME + LIVE LABEL — dispatched to profile partials
   ══════════════════════════════════════════════════════════════════ #}
{% if envelope_stops | default([]) %}
{% include "frames/marquee-horizontal/chrome-content.j2" %}
{% else %}
{% include "frames/marquee-horizontal/brutalist-content.j2" %}
{% endif %}

{# ═══ Scrolling content ═══ #}
<g clip-path="url(#{{ uid }}-scroll-clip)">
  <g data-hw-zone="scroll-track">
    <animateTransform attributeName="transform" type="translate"
        from="0 0" to="-{{ sd }} 0"
        dur="{{ dur }}s" repeatCount="indefinite"/>
    {# Set A — letter-spacing on word tspans only (not separators) for accurate measurement #}
    <text y="{{ mh // 2 }}" dominant-baseline="central"
          font-family="{{ scroll_font_family | default('var(--dna-font-mono, ui-monospace, monospace)') }}"
          font-size="13">
{% for item in scroll_items %}
      <tspan {% if loop.first %}x="{{ start_x }}"{% else %}dx="{{ dx }}"{% endif %}
             fill="{{ item.color | default('var(--dna-ink-primary)') }}" letter-spacing=".5"
             {% if item.font_weight | default('') %}font-weight="{{ item.font_weight }}"{% endif %}
      >{{ item.text }}</tspan>
{% if not loop.last %}
      <tspan dx="{{ dx }}" fill="{{ separator_color | default('var(--dna-border)') }}"{% if separator_opacity | default('') %} opacity="{{ separator_opacity }}"{% endif %}>{{ separator | default('■') }}</tspan>
{% endif %}
{% endfor %}
    </text>
    {# Set B (seamless loop at +scroll_distance) #}
    <text y="{{ mh // 2 }}" dominant-baseline="central"
          font-family="{{ scroll_font_family | default('var(--dna-font-mono, ui-monospace, monospace)') }}"
          font-size="13">
{% for item in scroll_items %}
      <tspan {% if loop.first %}x="{{ start_x + sd }}"{% else %}dx="{{ dx }}"{% endif %}
             fill="{{ item.color | default('var(--dna-ink-primary)') }}" letter-spacing=".5"
             {% if item.font_weight | default('') %}font-weight="{{ item.font_weight }}"{% endif %}
      >{{ item.text }}</tspan>
{% if not loop.last %}
      <tspan dx="{{ dx }}" fill="{{ separator_color | default('var(--dna-border)') }}"{% if separator_opacity | default('') %} opacity="{{ separator_opacity }}"{% endif %}>{{ separator | default('■') }}</tspan>
{% endif %}
{% endfor %}
    </text>
  </g>
</g>

{# ═══ Edge fades ═══ #}
<rect x="{{ cx }}" y="0" width="{{ fw }}" height="{{ mh }}"
      fill="url(#{{ uid }}-fade-l)"/>
<rect x="{{ mw - fw }}" y="0" width="{{ fw }}" height="{{ mh }}"
      fill="url(#{{ uid }}-fade-r)"/>

{# ═══ Top/bottom accent lines (guard on data) ═══ #}
{% if show_accent_lines | default(false) %}
<rect x="{{ cx }}" y="0" width="{{ mw - cx }}" height="1"
      fill="var(--dna-signal)" opacity="{{ accent_line_opacity | default(0.2) }}"/>
<rect x="{{ cx }}" y="{{ mh - 1 }}" width="{{ mw - cx }}" height="1"
      fill="var(--dna-signal)" opacity="{{ accent_line_opacity | default(0.2) }}"/>
{% endif %}

{# Specular sweep removed from horizontal per v2 spec #}
{% endblock %}
