{# Primer STRIP — dark substrate card: full-bleed rounded
   surface_1→surface_0 card ringed by an inner edge-highlight stroke + 1px
   border. NO drop shadow: on a full-bleed embedded artifact the viewBox clips
   a shadow everywhere except the transparent corner notches outside the rx10
   edge, where the residue reads as smudges on the README ground — the
   surface_1 crown and the edge highlight carry the lift instead. Identical
   structure to the light partial; substrate differences live in
   primer-defs.j2. All geometry resolver-supplied (strip_card /
   strip_inner_highlight / strip_outer_border); zero arithmetic. #}
<rect x="{{ strip_card.x }}" y="{{ strip_card.y }}" width="{{ strip_card.w }}" height="{{ strip_card.h }}" rx="{{ strip_card.rx }}" fill="url(#{{ uid }}-bg)"/>
<rect x="{{ strip_inner_highlight.x }}" y="{{ strip_inner_highlight.y }}" width="{{ strip_inner_highlight.w }}" height="{{ strip_inner_highlight.h }}" rx="{{ strip_inner_highlight.rx }}" fill="none" stroke="url(#{{ uid }}-lp)" stroke-width="{{ strip_inner_highlight.stroke_w }}"/>
<rect x="{{ strip_outer_border.x }}" y="{{ strip_outer_border.y }}" width="{{ strip_outer_border.w }}" height="{{ strip_outer_border.h }}" rx="{{ strip_outer_border.rx }}" fill="none" stroke="{{ _genome_raw.stroke }}" stroke-width="{{ strip_outer_border.stroke_w }}"/>
