{# Primer STRIP — light substrate card: full-bleed rounded
   white→tint card ringed by a bright inner edge-highlight (white crown →
   faint ink bottom tint) + 1px border. NO drop shadow — the viewBox would
   clip it to corner-notch smudges (see the dark partial); the white crown
   and the stroke border carry the edge. All geometry resolver-supplied
   (strip_card / strip_inner_highlight / strip_outer_border); zero
   arithmetic here. #}
<rect x="{{ strip_card.x }}" y="{{ strip_card.y }}" width="{{ strip_card.w }}" height="{{ strip_card.h }}" rx="{{ strip_card.rx }}" fill="url(#{{ uid }}-bg)"/>
<rect x="{{ strip_inner_highlight.x }}" y="{{ strip_inner_highlight.y }}" width="{{ strip_inner_highlight.w }}" height="{{ strip_inner_highlight.h }}" rx="{{ strip_inner_highlight.rx }}" fill="none" stroke="url(#{{ uid }}-lp)" stroke-width="{{ strip_inner_highlight.stroke_w }}"/>
<rect x="{{ strip_outer_border.x }}" y="{{ strip_outer_border.y }}" width="{{ strip_outer_border.w }}" height="{{ strip_outer_border.h }}" rx="{{ strip_outer_border.rx }}" fill="none" stroke="{{ _genome_raw.stroke }}" stroke-width="{{ strip_outer_border.stroke_w }}"/>
