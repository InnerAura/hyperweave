{# Chrome vertical-marquee content: env-map bezel, well, horizon header, header text.
   Specimen: chrome-horizon-marquees-v2.
   Layer order: envelope -> groove -> well -> horizon header -> top specular catch. #}
<g clip-path="url(#{{ uid }}-outer)" filter="url(#{{ uid }}-shadow)">
  <rect width="{{ vw }}" height="{{ vh }}" rx="4" fill="url(#{{ uid }}-envelope)"/>
</g>
<rect x="2" y="2" width="{{ vw - 4 }}" height="{{ vh - 4 }}" rx="3" fill="none" stroke="#000510" stroke-width=".6"/>
<rect x="3" y="3" width="{{ vw - 6 }}" height="{{ vh - 6 }}" rx="2" fill="url(#{{ uid }}-well)"/>
{# Specular sweep removed — causes text blur on chrome marquees #}
{# Horizon-band header — single rect, flush to well top #}
<rect x="3" y="3" width="{{ vw - 6 }}" height="{{ hh }}" rx="2" fill="url(#{{ uid }}-hdr)"/>
<rect x="3" y="{{ hh }}" width="{{ vw - 6 }}" height="6" fill="url(#{{ uid }}-hdr)"/>
{# Top specular catch #}
<rect x="40" y="3" width="{{ vw - 80 }}" height=".5" fill="{{ specular_light }}" opacity=".08"/>

{# Header content — chrome style #}
<text x="16" y="25"
      font-family="'Inter',system-ui,sans-serif" font-size="11" font-weight="800"
      fill="var(--dna-surface, #000A14)" letter-spacing="2">{{ header_label | default('SYSTEM TELEMETRY') | upper }}</text>
{# LIVE text #}
<text x="358" y="23" text-anchor="end"
      font-family="var(--dna-font-mono, 'Courier New', monospace)"
      font-size="8" font-weight="700" fill="var(--dna-surface, #000A14)">{{ marquee_label | default('LIVE') }}</text>
{# Pulsing dot #}
{% if show_pulse | default(true) %}
{% set lds = live_dot_size | default(8) %}
<rect x="364" y="15" width="{{ lds }}" height="{{ lds }}" rx="1"
      fill="var(--dna-surface, #000A14)">
  <animate attributeName="opacity" values="1;.15;1" dur="{{ pulse_dur | default('2.618s') }}"
           repeatCount="indefinite"/>
</rect>
{% endif %}

{# Divider below header — chrome style #}
<line x1="3" y1="{{ scroll_top - 2 }}" x2="{{ vw - 3 }}" y2="{{ scroll_top - 2 }}"
      stroke="var(--dna-signal)" stroke-width=".5" stroke-opacity=".25"/>
