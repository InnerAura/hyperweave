{# Chrome vertical-marquee defs: envelope, shadow, well, horizon-band header gradient.
   Specimen: chrome-horizon-marquees-v2.
   Guard on data presence (envelope_stops), not profile identity. #}
  <linearGradient id="{{ uid }}-envelope" x1="0" x2="0" y1="0" y2="1">
  {% for stop in envelope_stops %}
    <stop offset="{{ stop.offset }}" stop-color="{{ stop.color }}"/>
  {% endfor %}
  </linearGradient>
  <filter id="{{ uid }}-shadow" x="-2%" y="-2%" width="104%" height="106%">
    <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#000" flood-opacity=".35"/>
  </filter>
  <linearGradient id="{{ uid }}-well" x1="0" x2="0" y1="0" y2="1">
    <stop offset="0%" stop-color="{{ well_top | default('#0C1E2E') }}"/>
    <stop offset="100%" stop-color="{{ well_bottom | default('#06101A') }}"/>
  </linearGradient>
  {# Horizon-band header — derived from genome envelope_stops (not hardcoded) #}
  {% if envelope_stops | default([]) | length >= 7 %}
  <linearGradient id="{{ uid }}-hdr" x1="0" y1="0" x2="1" y2="0">
    <stop offset="0%" stop-color="{{ envelope_stops[2].color }}" stop-opacity="0.7"/>
    <stop offset="30%" stop-color="{{ envelope_stops[3].color }}" stop-opacity="0.85"/>
    <stop offset="50%" stop-color="{{ envelope_stops[4].color }}" stop-opacity="0.95"/>
    <stop offset="70%" stop-color="{{ envelope_stops[3].color }}" stop-opacity="0.85"/>
    <stop offset="100%" stop-color="{{ envelope_stops[2].color }}" stop-opacity="0.7"/>
  </linearGradient>
  {% else %}
  <linearGradient id="{{ uid }}-hdr" x1="0" y1="0" x2="1" y2="0">
    <stop offset="0%" stop-color="{{ highlight_color | default('#6AACC8') }}" stop-opacity="0.4"/>
    <stop offset="50%" stop-color="{{ highlight_color | default('#6AACC8') }}" stop-opacity="0.8"/>
    <stop offset="100%" stop-color="{{ highlight_color | default('#6AACC8') }}" stop-opacity="0.4"/>
  </linearGradient>
  {% endif %}
  <clipPath id="{{ uid }}-outer"><rect width="{{ vw }}" height="{{ vh }}" rx="4"/></clipPath>
  <clipPath id="{{ uid }}-inner"><rect x="3" y="3" width="{{ vw - 6 }}" height="{{ vh - 6 }}" rx="2"/></clipPath>
  {# Specular sweep def removed from chrome marquees #}
