{# Chrome banner content — motorsport typography (specimen: chrome-horizon-banner.svg).
   Transparent background, Impact italic, env-map fill, skewX(-10),
   accent stripe, Courier New labels. Extracted verbatim from the
   legacy banner.svg.j2 inline chrome branch. #}
{% set chrome_fs = title_font_size | default(145 if is_full else 64) %}
{% set chrome_text_y = (bh * 0.44) | int %}
{% set stripe_y = (bh * 0.58) | int %}
{% set label_start_y = stripe_y + 35 %}
{% set chrome_rx = chrome_corner | default('6') %}

{# === Chrome background: TRANSPARENT (specimen: chrome-horizon-banner.svg) === #}
{# No background fill — chrome banners are transparent for universal placement #}

{# Chrome text with env-map fill, dark stroke for light-mode contrast, skew #}
{% if motion_id and motion_id != 'static' %}
{# Override kinetic motion text to use chrome typography + env-map fill.
   CSS !important beats SVG presentation attributes (font-family="..."). #}
<style>
  .hw-motion-target text,
  .hw-motion-target .hw-motion-bars-text,
  .hw-motion-target .hw-motion-cascade-text,
  .hw-motion-target .hw-motion-broadcast-normal,
  .hw-motion-target .hw-motion-broadcast-final,
  .hw-motion-target .hw-motion-crash-c,
  .hw-motion-target .hw-motion-breach-materialized,
  .hw-motion-target .hw-motion-breach-ghost,
  .hw-motion-target .hw-motion-pulse-headline {
    font-family: 'Impact','Arial Black',system-ui,sans-serif !important;
    font-style: italic !important;
    letter-spacing: -3px !important;
    fill: url(#{{ uid }}-chrome-env) !important;
    stroke: rgba(0,10,20,0.35);
    stroke-width: 1px;
    paint-order: stroke fill;
  }
</style>
{% endif %}
<g data-hw-zone="title"{% if motion_id and motion_id != 'static' %} class="hw-motion-target"{% endif %}>
{% if motion_id and motion_id != 'static' %}
  {# Motion SVG uses absolute coordinates — do NOT wrap in translate/skew #}
  {{ motion_svg | safe }}
{% else %}
  <g filter="url(#{{ uid }}-glow)" transform="translate({{ text_cx }}, {{ chrome_text_y }}) skewX(-10)">
    <text x="0" y="0" text-anchor="middle"
          font-family="'Impact','Arial Black',system-ui,sans-serif"
          font-size="{{ chrome_fs }}" font-weight="900" font-style="italic"
          letter-spacing="-3px"
          fill="url(#{{ uid }}-chrome-env)"
          stroke="rgba(0,10,20,0.35)" stroke-width="1"
          paint-order="stroke fill"
          text-rendering="geometricPrecision"
          filter="url(#{{ uid }}-shadow)">{{ banner_title | default(title_text) }}</text>
  </g>
{% endif %}
</g>

{# Accent stripe divider #}
<rect x="{{ (bw * 0.11) | int }}" y="{{ stripe_y }}"
      width="{{ (bw * 0.78) | int }}" height="2"
      fill="url(#{{ uid }}-chrome-env)" opacity="0.6"/>

{# Labels — Courier New monospace, chrome accent color #}
{% if banner_label %}
<g transform="translate({{ text_cx }}, {{ label_start_y }})">
  <text text-anchor="middle"
        font-family="'Courier New',monospace"
        font-size="11" fill="#3d7fad"
        letter-spacing="4px"
        text-transform="uppercase">{{ banner_label | upper }}</text>
</g>
{% endif %}
{% if banner_subtitle %}
<g transform="translate({{ text_cx }}, {{ label_start_y + 20 }})">
  <text text-anchor="middle"
        font-family="'Courier New',monospace"
        font-size="11" fill="#3d7fad"
        letter-spacing="4px"
        text-transform="uppercase">{{ banner_subtitle | upper }}</text>
</g>
{% endif %}
