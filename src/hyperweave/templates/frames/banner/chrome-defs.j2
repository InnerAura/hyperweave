{# Chrome banner defs: env-map gradient, glow/shadow/bevel filters, well gradient.
   Guard on data presence (envelope_stops), not profile identity. #}
{# Chrome env-map gradient (HDRI simulation, animated y1/y2) #}
<linearGradient id="{{ uid }}-chrome-env" x1="0" x2="0" y1="-0.1" y2="0.9">
{% for stop in envelope_stops %}
  <stop offset="{{ stop.offset }}" stop-color="{{ stop.color }}"/>
{% endfor %}
  <animateTransform attributeName="gradientTransform" type="translate"
    values="0 -0.2; 0 0.2; 0 -0.2" dur="6s"
    repeatCount="indefinite" calcMode="spline"
    keySplines="0.4 0 0.2 1;0.4 0 0.2 1"/>
</linearGradient>
{# Edge glow filter — accent-colored bloom #}
<filter id="{{ uid }}-glow" x="-15%" y="-15%" width="130%" height="130%">
  <feGaussianBlur in="SourceAlpha" stdDeviation="3" result="blur"/>
  <feFlood flood-color="{{ highlight_color | default(specular_light | default('#6AACC8')) }}" flood-opacity="0.4"/>
  <feComposite in2="blur" operator="in" result="glow"/>
  <feMerge>
    <feMergeNode in="glow"/>
    <feMergeNode in="SourceGraphic"/>
  </feMerge>
</filter>
{# Drop shadow for text depth #}
<filter id="{{ uid }}-shadow" x="-20%" y="-20%" width="140%" height="140%">
  <feDropShadow dx="0" dy="3" stdDeviation="6"
                flood-color="#000" flood-opacity="0.25"/>
</filter>
{# Product-weight bevel — shadow + light specular (satin chrome specimens) #}
<filter id="{{ uid }}-bevel" x="-2%" y="-4%" width="104%" height="110%">
  <feDropShadow dx="0" dy="1.5" stdDeviation="2.5" flood-color="#000" flood-opacity="{{ bevel_shadow_opacity | default('0.30') }}"/>
  <feSpecularLighting in="SourceAlpha" surfaceScale="1.0" specularConstant="0.4"
                      specularExponent="30" lighting-color="{{ specular_light | default('#6AACC8') }}" result="s">
    <feDistantLight azimuth="225" elevation="50"/>
  </feSpecularLighting>
  <feComposite in="s" in2="SourceAlpha" operator="in" result="sc"/>
  <feComposite in="SourceGraphic" in2="sc" operator="arithmetic" k1="0" k2="1" k3="0.12" k4="0"/>
</filter>
{# Well gradient (lightened per satin specimens) #}
<linearGradient id="{{ uid }}-well" x1="0" x2="0" y1="0" y2="1">
  <stop offset="0%" stop-color="{{ well_top | default('#0C1E2E') }}"/>
  <stop offset="100%" stop-color="{{ well_bottom | default('#06101A') }}"/>
</linearGradient>
