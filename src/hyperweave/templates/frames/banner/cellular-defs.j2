{# Cellular banner defs — bifamily flank pulse + kinetic text wipe +
   phantom-cursor + scan-line. Mirrors specimen cellular-automata-hero-banner-v2. #}
<linearGradient id="{{ uid }}-tglow" x1="0" y1="0" x2="1" y2="0">
  <stop offset="0%" stop-color="{{ family_blue_pattern_cells[0] | default('#1E849A') }}" stop-opacity="0"/>
  <stop offset="50%" stop-color="{{ family_blue_pattern_cells[0] | default('#1E849A') }}" stop-opacity=".12"/>
  <stop offset="100%" stop-color="{{ family_purple_pattern_cells[0] | default('#6B3B8A') }}" stop-opacity="0"/>
</linearGradient>
<clipPath id="{{ uid }}-panel-clip"><rect x="0" y="0" width="100%" height="100%"/></clipPath>
<style>{{ font_faces | safe }}
.cb1{animation:cbp {{ cellular_pulse_base_duration | default('6s') }} ease-in-out infinite;will-change:opacity}
.cb2{animation:cbp {{ cellular_pulse_base_duration | default('6s') }} ease-in-out infinite 1.5s;will-change:opacity}
.cb3{animation:cbp {{ cellular_pulse_base_duration | default('6s') }} ease-in-out infinite 3s;will-change:opacity}
.cb4{animation:cbp {{ cellular_pulse_base_duration | default('6s') }} ease-in-out infinite 4.5s;will-change:opacity}
.cbf{animation:cbp {{ cellular_pulse_fast_duration | default('3s') }} ease-in-out infinite 0.5s;will-change:opacity}
.cbd{opacity:.07}
@keyframes cbp{0%,100%{opacity:.04}30%{opacity:.7}50%{opacity:.2}70%{opacity:.55}}
/* Kinetic text reveal — clip-path wipe (1.618s phi-timed) */
.hb-title{clip-path:inset(0 100% 0 0);animation:hb-wipe 1.618s cubic-bezier(.16,1,.3,1) .5s forwards;will-change:clip-path}
.hb-sub{clip-path:inset(0 100% 0 0);animation:hb-wipe 1.618s cubic-bezier(.16,1,.3,1) 1.2s forwards;will-change:clip-path}
.hb-line{transform:scaleX(0);transform-origin:left;animation:hb-grow 1s ease-out 2s forwards;will-change:transform}
.hb-tag{opacity:0;animation:hb-fade .6s ease-out 2.4s forwards;will-change:opacity}
.hb-cursor{opacity:0;animation:hb-blink 1s step-end 2.1s infinite;will-change:opacity}
.hb-cursor-text{opacity:0;animation:hb-cursor-reveal .1s linear 2.1s forwards}
@keyframes hb-wipe{to{clip-path:inset(0 0 0 0)}}
@keyframes hb-grow{to{transform:scaleX(1)}}
@keyframes hb-fade{to{opacity:1}}
@keyframes hb-blink{0%,100%{opacity:0}50%{opacity:1}}
@keyframes hb-cursor-reveal{to{opacity:1}}
/* Horizontal scan line (8s linear) */
.hb-scan{animation:hb-scanmove 8s linear infinite;will-change:transform}
@keyframes hb-scanmove{0%{transform:translateY(-100%)}100%{transform:translateY(100%)}}
@media(prefers-reduced-motion:reduce){
  .cb1,.cb2,.cb3,.cb4,.cbf,.hb-title,.hb-sub,.hb-line,.hb-tag,.hb-cursor,.hb-cursor-text,.hb-scan{animation:none!important;opacity:1!important;clip-path:none!important;transform:none!important}
}
</style>
