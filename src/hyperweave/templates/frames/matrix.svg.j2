{# Matrix frame — structured comparison table.
   Paradigm dispatch via slug interpolation (Invariant 12): custom genomes add
   matrix support by dropping frames/matrix/{paradigm}-defs.j2 +
   {paradigm}-content.j2 and a paradigms.matrix entry — zero Python edits.
   Primer is the matrix's first (and v0.4.0-alpha.2 only) chassis. #}
{% extends "document.svg.j2" %}
{% block defs %}
{% include "frames/matrix/" ~ (paradigm | default("primer")) ~ "-defs.j2" %}
{% endblock %}
{% block content %}
{% include "frames/matrix/" ~ (paradigm | default("primer")) ~ "-content.j2" %}
{% endblock %}
