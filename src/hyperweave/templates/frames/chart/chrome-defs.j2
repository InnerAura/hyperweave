{# Chrome chart defs: full material stack (envelope, well, bevel, text gradients,
   line glow, horizon glow, end glow, rim sweep), clip-path.
   Ported from tier2/genomes/chrome-horizon/github-star-history-card-v6.svg #}

{# Canonical 11-stop chrome envelope #}
<linearGradient id="{{ uid }}-env" x1="0" x2="0" y1="-0.1" y2="0.9">
  <stop offset="0%" stop-color="#000A14"/>
  <stop offset="12%" stop-color="#0A2540"/>
  <stop offset="25%" stop-color="#1A4A6E"/>
  <stop offset="36%" stop-color="#3A7EA8"/>
  <stop offset="44%" stop-color="#6AACC8"/>
  <stop offset="50%" stop-color="#C8DAE6"/>
  <stop offset="56%" stop-color="#B8A888"/>
  <stop offset="64%" stop-color="#6A5840"/>
  <stop offset="75%" stop-color="#2A2218"/>
  <stop offset="88%" stop-color="#100E0A"/>
  <stop offset="100%" stop-color="#060810"/>
  <animateTransform attributeName="gradientTransform" type="translate"
    values="0 -0.2; 0 0.2; 0 -0.2" dur="6s"
    repeatCount="indefinite" calcMode="spline"
    keySplines="0.4 0 0.2 1;0.4 0 0.2 1"/>
</linearGradient>

{# Dark well #}
<linearGradient id="{{ uid }}-well" x1="0" x2="0" y1="0" y2="1">
  <stop offset="0%" stop-color="#020617"/>
  <stop offset="100%" stop-color="#0B1121"/>
</linearGradient>

{# Chrome blue title gradient #}
<linearGradient id="{{ uid }}-ct-title" x1="0" y1="0" x2="1" y2="0">
  <stop offset="0%" stop-color="#5A8AAA"/>
  <stop offset="15%" stop-color="#A8D4F0"/>
  <stop offset="35%" stop-color="#D8ECF8"/>
  <stop offset="50%" stop-color="#FFFFFF"/>
  <stop offset="65%" stop-color="#D8ECF8"/>
  <stop offset="85%" stop-color="#A8D4F0"/>
  <stop offset="100%" stop-color="#5A8AAA"/>
</linearGradient>

{# Icy silver hero gradient #}
<linearGradient id="{{ uid }}-ct-hero" x1="0" y1="0" x2="1" y2="0">
  <stop offset="0%" stop-color="#94A3B8"/>
  <stop offset="20%" stop-color="#CBD5E1"/>
  <stop offset="40%" stop-color="#F1F5F9"/>
  <stop offset="50%" stop-color="#FFFFFF"/>
  <stop offset="60%" stop-color="#F1F5F9"/>
  <stop offset="80%" stop-color="#CBD5E1"/>
  <stop offset="100%" stop-color="#94A3B8"/>
</linearGradient>

{# Cyan divider gradient #}
<linearGradient id="{{ uid }}-sep" x1="0" y1="0" x2="1" y2="0">
  <stop offset="0%" stop-color="#5BA3D4" stop-opacity="0"/>
  <stop offset="30%" stop-color="#5BA3D4" stop-opacity="0.35"/>
  <stop offset="50%" stop-color="#A8D4F0" stop-opacity="0.5"/>
  <stop offset="70%" stop-color="#5BA3D4" stop-opacity="0.35"/>
  <stop offset="100%" stop-color="#5BA3D4" stop-opacity="0"/>
</linearGradient>

{# Rim sweep #}
<linearGradient id="{{ uid }}-rim" x1="0" y1="0" x2="1" y2="0">
  <stop offset="0%"  stop-color="#A8D4F0" stop-opacity="0"/>
  <stop offset="35%" stop-color="#A8D4F0" stop-opacity="0"/>
  <stop offset="46%" stop-color="#C8DAE6" stop-opacity="0.3"/>
  <stop offset="50%" stop-color="#FFFFFF" stop-opacity="0.6"/>
  <stop offset="54%" stop-color="#C8DAE6" stop-opacity="0.3"/>
  <stop offset="65%" stop-color="#A8D4F0" stop-opacity="0"/>
  <stop offset="100%" stop-color="#A8D4F0" stop-opacity="0"/>
  <animate attributeName="x1" values="-0.4;1.0;-0.4" dur="18s" repeatCount="indefinite" calcMode="spline" keySplines="0.4 0 0.6 1;0.4 0 0.6 1"/>
  <animate attributeName="x2" values="0.4;1.8;0.4" dur="18s" repeatCount="indefinite" calcMode="spline" keySplines="0.4 0 0.6 1;0.4 0 0.6 1"/>
</linearGradient>

<filter id="{{ uid }}-bevel" x="-2%" y="-3%" width="104%" height="108%">
  <feDropShadow dx="0" dy="3" stdDeviation="5" flood-color="#000000" flood-opacity="0.5"/>
  <feSpecularLighting in="SourceAlpha" surfaceScale="1.8" specularConstant="0.6" specularExponent="22" lighting-color="#A8D4F0" result="spec">
    <feDistantLight azimuth="225" elevation="45"/>
  </feSpecularLighting>
  <feComposite in="spec" in2="SourceAlpha" operator="in" result="specIn"/>
  <feComposite in="SourceGraphic" in2="specIn" operator="arithmetic" k1="0" k2="1" k3="0.2" k4="0"/>
</filter>

{# Data line glow #}
<filter id="{{ uid }}-lineglow" x="-15%" y="-50%" width="130%" height="200%">
  <feGaussianBlur in="SourceAlpha" stdDeviation="9" result="blur1"/>
  <feFlood flood-color="#FFFFFF" flood-opacity="0.55"/>
  <feComposite in2="blur1" operator="in" result="glow1"/>
  <feGaussianBlur in="SourceAlpha" stdDeviation="3" result="blur2"/>
  <feFlood flood-color="#38BDF8" flood-opacity="0.95"/>
  <feComposite in2="blur2" operator="in" result="glow2"/>
  <feMerge>
    <feMergeNode in="glow1"/>
    <feMergeNode in="glow2"/>
    <feMergeNode in="SourceGraphic"/>
  </feMerge>
</filter>

<filter id="{{ uid }}-horizon-glow" x="-5%" y="-400%" width="110%" height="900%">
  <feGaussianBlur in="SourceGraphic" stdDeviation="3.5" result="blur"/>
  <feMerge>
    <feMergeNode in="blur"/>
    <feMergeNode in="SourceGraphic"/>
  </feMerge>
</filter>

<filter id="{{ uid }}-endglow" x="-80%" y="-80%" width="260%" height="260%">
  <feGaussianBlur stdDeviation="5" result="b"/>
  <feFlood flood-color="#FFFFFF" flood-opacity="0.75"/>
  <feComposite in2="b" operator="in" result="g"/>
  <feMerge>
    <feMergeNode in="g"/>
    <feMergeNode in="SourceGraphic"/>
  </feMerge>
</filter>

<clipPath id="{{ uid }}-clip"><rect width="{{ width }}" height="{{ height }}" rx="6"/></clipPath>
{{ chart_defs | default("") | safe }}

<style>
  {{ font_faces | safe }}
  text { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); shape-rendering: geometricPrecision; }
  .{{ uid }}-label { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 11px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; fill: var(--dna-signal, #5BA3D4); }
  .{{ uid }}-identity { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 12px; font-weight: 700; letter-spacing: 0.06em; fill: #E0ECF6; }
  .{{ uid }}-title { font-family: var(--dna-font-display, 'Orbitron', sans-serif); font-size: 44px; font-weight: 900; letter-spacing: 0.04em; fill: url(#{{ uid }}-ct-title); }
  .{{ uid }}-hero { font-family: var(--dna-font-display, 'Orbitron', sans-serif); font-size: 48px; font-weight: 900; letter-spacing: -0.01em; fill: url(#{{ uid }}-ct-hero); }
  .{{ uid }}-subtitle { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 9px; font-weight: 700; letter-spacing: 0.22em; text-transform: uppercase; fill: var(--dna-ink-muted, #7A9AB8); opacity: 0.9; }
  .{{ uid }}-hero-label { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 9px; font-weight: 700; letter-spacing: 0.20em; text-transform: uppercase; fill: var(--dna-signal, #5BA3D4); }
  .{{ uid }}-axis-y { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 9px; font-weight: 700; letter-spacing: 0.08em; fill: #C8DAE6; opacity: 0.95; }
  .{{ uid }}-axis-x { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 9px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; fill: #C8DAE6; opacity: 0.9; }
  .{{ uid }}-milestone { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 8.5px; font-weight: 700; letter-spacing: 0.14em; fill: #FFFFFF; }
  .{{ uid }}-foot { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 7.5px; font-weight: 600; letter-spacing: 0.14em; fill: var(--dna-ink-muted, #7A9AB8); opacity: 0.8; }
  .{{ uid }}-brand { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 7.5px; font-weight: 700; letter-spacing: 0.28em; fill: var(--dna-ink-muted, #7A9AB8); opacity: 0.65; }
  /* Chart engine fragment classes — chrome aesthetic (match tier2 target) */
  .hw-chart-axis { stroke: #38BDF8; stroke-width: 0.8; fill: none; opacity: 0.55; }
  .hw-chart-gridline { stroke: #A8D4F0; stroke-width: 0.4; opacity: 0.18; fill: none; }
  .hw-chart-line { stroke: #60E0FF; stroke-width: 4; stroke-linecap: round; stroke-linejoin: round; filter: url(#{{ uid }}-lineglow); }
  .hw-chart-area { fill: none; }
  .hw-chart-area-smooth { fill: none; }
  [data-hw-zone="markers"] > rect { fill: #FFFFFF; stroke: #000A14; stroke-width: 0.7; }
  .hw-chart-endpoint { animation: {{ uid }}-breathe 2.618s ease-in-out infinite; will-change: opacity; }
  .hw-chart-milestone-line { stroke: #38BDF8; stroke-width: 0.5; opacity: 0.3; }
  .hw-chart-milestone-label { font-family: var(--dna-font-mono, 'JetBrains Mono', monospace); font-size: 8.5px; font-weight: 700; letter-spacing: 0.14em; fill: #FFFFFF; }
  [data-hw-status="active"], [data-hw-status="passing"] { --hw-core: var(--dna-status-passing-core, #22C55E); }
  [data-hw-status="warning"] { --hw-core: var(--dna-status-warning-core, #F59E0B); }
  [data-hw-status="critical"], [data-hw-status="failing"] { --hw-core: var(--dna-status-failing-core, #EF4444); }
  @keyframes {{ uid }}-breathe { 0%,100% { opacity: 0.55; } 50% { opacity: 1; } }
  @keyframes {{ uid }}-horizon-pulse { 0%,100% { opacity: 0.8; } 50% { opacity: 1; } }
  .{{ uid }}-dia, .{{ uid }}-end, .{{ uid }}-mile { animation: {{ uid }}-breathe 2.618s ease-in-out infinite; will-change: opacity; }
  .{{ uid }}-horizon { animation: {{ uid }}-horizon-pulse 4.236s ease-in-out infinite; will-change: opacity; }
  @media (prefers-reduced-motion: reduce) {
    .{{ uid }}-dia, .{{ uid }}-end, .{{ uid }}-mile, .{{ uid }}-horizon { animation: none !important; opacity: 0.9; }
    animate, animateTransform { display: none !important; }
  }
</style>
