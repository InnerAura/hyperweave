{# Kinetic typography: breach -- quantum tunneling scan-line reveals materialized text.
   Specimen: quantum_tunneling_breach.svg
   Ghost text (dim) always visible. Bright text revealed through moving scan-line mask.
   Glitch text offset for chromatic aberration.
   Context: uid, title, cx, cy, fs, w, h, ty, txt_attrs #}
<defs>
  <linearGradient id="{{ uid }}-scan-grad" x1="0" y1="0" x2="1" y2="0">
    <stop offset="0%" stop-color="black"/>
    <stop offset="47%" stop-color="black"/>
    <stop offset="50%" stop-color="white"/>
    <stop offset="53%" stop-color="black"/>
    <stop offset="100%" stop-color="black"/>
    <animate attributeName="x1" from="-1" to="1" dur="2s" repeatCount="indefinite"/>
    <animate attributeName="x2" from="0" to="2" dur="2s" repeatCount="indefinite"/>
  </linearGradient>
  <mask id="{{ uid }}-scan-mask">
    <rect x="0" y="0" width="{{ w }}" height="{{ h }}" fill="url(#{{ uid }}-scan-grad)"/>
  </mask>
</defs>
<text class="hw-motion-breach-ghost" {{ txt_attrs }}
      fill="var(--dna-ink-muted)">{{ title }}</text>
<g mask="url(#{{ uid }}-scan-mask)">
  <text class="hw-motion-breach-materialized" {{ txt_attrs }}
        fill="var(--dna-ink-primary)"
        style="filter:drop-shadow(0 0 10px var(--dna-ink-primary))">{{ title }}</text>
</g>
<text class="hw-motion-breach-glitch" {{ txt_attrs }}
      fill="var(--dna-signal)" opacity="0.3"
      dx="3" dy="-2">{{ title }}</text>
