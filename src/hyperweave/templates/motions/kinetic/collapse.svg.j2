{# Kinetic typography: collapse -- z-axis parallax tunnel zoom with 3 depth layers.
   Specimen: z_axis_illusion_via_exponential_scale_blur_convergence.svg
   Three text layers (back/mid/front) cycle scale(0.01)->1->5 with staggered delays
   and SMIL-driven Gaussian blur for depth-of-field.
   transform-origin uses cx/ty (text center, NOT cy which is banner center).
   Outputs ONLY: filter def + 3 text layers. NO background rects.
   Context: uid, title, cx, cy, fs, w, h, ty, txt_attrs #}
<defs>
  <filter id="hw-motion-collapse-blur" x="-50%" y="-50%" width="200%" height="200%">
    <feGaussianBlur in="SourceGraphic" stdDeviation="0">
      <animate attributeName="stdDeviation"
               values="50; 0; 0; 80" dur="4s" repeatCount="indefinite"/>
    </feGaussianBlur>
  </filter>
</defs>
<text class="hw-motion-collapse-text hw-motion-collapse-back"
      {{ txt_attrs }} style="transform-origin:{{ cx }}px {{ ty }}px">{{ title }}</text>
<text class="hw-motion-collapse-text hw-motion-collapse-mid"
      {{ txt_attrs }} style="transform-origin:{{ cx }}px {{ ty }}px">{{ title }}</text>
<text class="hw-motion-collapse-text hw-motion-collapse-front"
      {{ txt_attrs }} style="transform-origin:{{ cx }}px {{ ty }}px">{{ title }}</text>
