{# HyperWeave Error Badge -- universal SMPTE NO SIGNAL fallback.

   Rendered by serve/app.py whenever an artifact cannot be composed
   (genome missing, template not found, validation failure, any compose
   exception). Single template -- the HTTP layer parameterizes the
   status code so a missing genome shows ERR_404, a Pydantic validation
   miss shows ERR_422, and a generic compose failure shows ERR_500.

   Required context (passed by `_error_badge` in serve/app.py):
     status_code -- numeric HTTP status (404, 422, 500, ...).
     message     -- human-readable error message (truncated).
                    Goes into <title>/<desc> for screen readers; the
                    visual surface only shows the status code.
     uid         -- short ID prefix (e.g. "hw-err-04321") that scopes
                    every gradient, filter, clip-path, class, and
                    keyframes name. Multiple error badges on the same
                    page render without DOM collisions.

   Aesthetic reference: tier2/genomes/__errors__/404-badge.svg
   SMPTE RP 219 color bars: white/yellow/cyan/green/magenta/red/blue
   at C0C0C0/C0C000/00C0C0/00C000/C000C0/C00000/0000C0.
#}
<svg xmlns="http://www.w3.org/2000/svg"
     xmlns:hw="https://hyperweave.app/hw/v1.0"
     viewBox="0 0 192 32" width="192" height="32"
     role="img" aria-labelledby="{{ uid }}-t {{ uid }}-d"
     data-hw-id="{{ uid }}"
     data-hw-type="badge"
     data-hw-class="error-state"
     data-hw-genome="signal-loss"
     data-hw-profile="memetic-tv"
     data-hw-variant="rainbow-static"
     data-hw-status-code="{{ status_code }}"
     data-hw-label="NO SIGNAL"
     data-hw-value="ERR_{{ status_code }}"
     data-hw-glyph="signal-loss"
     data-hw-variant="universal-fallback"
     data-hw-frame-treatment="chrome-rim-refined-seam"
     style="shape-rendering:geometricPrecision">
  <title id="{{ uid }}-t">NO SIGNAL · ERR_{{ status_code }}</title>
  <desc id="{{ uid }}-d">{{ message | xml_escape }}</desc>
  <metadata>
    <hw:artifact id="{{ uid }}" type="badge" class="error-state"
                 genome="signal-loss" status-code="{{ status_code }}"
                 frame="chrome-rim-refined-seam"/>
    <hw:provenance generator="hyperweave-error-fallback" source="error-badge.svg.j2"/>
    <hw:spec viewBox="0 0 192 32" theme="dark-only" a11y="WCAG-AA"
             cim-compliant="paint-ok" self-contained="true"/>
  </metadata>
  <defs>
    <linearGradient id="{{ uid }}-rim" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#E8E8E8"/>
      <stop offset="10%" stop-color="#B8B8B8"/>
      <stop offset="28%" stop-color="#787878"/>
      <stop offset="48%" stop-color="#3A3A3A"/>
      <stop offset="72%" stop-color="#1A1A1A"/>
      <stop offset="90%" stop-color="#0A0A0A"/>
      <stop offset="100%" stop-color="#020202"/>
    </linearGradient>
    <linearGradient id="{{ uid }}-vb" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#0C0C12"/>
      <stop offset="100%" stop-color="#040408"/>
    </linearGradient>
    <linearGradient id="{{ uid }}-seam" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%"   stop-color="#FF0040" stop-opacity="0"/>
      <stop offset="18%"  stop-color="#FF0040" stop-opacity="0.55"/>
      <stop offset="50%"  stop-color="#00E0FF" stop-opacity="0.82"/>
      <stop offset="82%"  stop-color="#FF0040" stop-opacity="0.55"/>
      <stop offset="100%" stop-color="#FF0040" stop-opacity="0"/>
    </linearGradient>
    <filter id="{{ uid }}-lift" x="-4%" y="-12%" width="108%" height="130%">
      <feDropShadow dx="0" dy="0.5" stdDeviation="0.6" flood-color="#000000" flood-opacity="0.32"/>
    </filter>
    <clipPath id="{{ uid }}-bars-clip">
      <rect x="2" y="2" width="117" height="28"/>
    </clipPath>
  </defs>
  <style>
    {{ font_faces | safe }}
    .{{ uid }}-bars{animation:{{ uid }}-bar-shift 4.2s ease-in-out infinite;will-change:filter}
    .{{ uid }}-scan{animation:{{ uid }}-scan 2.6s linear infinite;will-change:transform}
    .{{ uid }}-flick1{animation:{{ uid }}-flick 5.7s ease-in-out infinite}
    .{{ uid }}-flick2{animation:{{ uid }}-flick 4.3s ease-in-out infinite 1.2s}
    .{{ uid }}-glitch{animation:{{ uid }}-glitch 3.8s steps(1,end) infinite;will-change:transform}
    .{{ uid }}-err{animation:{{ uid }}-err-pulse 2.1s ease-in-out infinite;will-change:filter}
    @keyframes {{ uid }}-bar-shift{0%,100%{filter:saturate(1) hue-rotate(0deg)}45%{filter:saturate(1.18) hue-rotate(-3deg)}55%{filter:saturate(.92) hue-rotate(2deg)}}
    @keyframes {{ uid }}-scan{0%{transform:translateY(-2px)}100%{transform:translateY(30px)}}
    @keyframes {{ uid }}-flick{0%,92%,100%{opacity:.18}93%{opacity:0}94%{opacity:.42}95%{opacity:.05}}
    @keyframes {{ uid }}-glitch{0%,93%,100%{transform:translate(0,0)}94%{transform:translate(-1px,0)}95%{transform:translate(1px,0)}96%{transform:translate(0,0)}}
    @keyframes {{ uid }}-err-pulse{0%,100%{filter:drop-shadow(0 0 0 #FF3858)}50%{filter:drop-shadow(0 0 1.4px #FF3858)}}
    @media(prefers-reduced-motion:reduce){.{{ uid }}-bars,.{{ uid }}-scan,.{{ uid }}-flick1,.{{ uid }}-flick2,.{{ uid }}-glitch,.{{ uid }}-err{animation:none!important}}
    @media(forced-colors:active){text{fill:CanvasText!important}rect{stroke:CanvasText}}
  </style>

  {# ============ FRAME ============ #}
  <rect width="192" height="32" fill="url(#{{ uid }}-rim)" filter="url(#{{ uid }}-lift)"/>
  <rect x="1" y="1" width="190" height="30" fill="none" stroke="#000510" stroke-width="0.7"/>
  <rect x="2" y="2" width="188" height="28" fill="#040408"/>
  <rect x="22" y="2" width="166" height="1" fill="#E8E8E8" opacity="0.20"/>
  <rect x="22" y="29.5" width="166" height="0.5" fill="#020202" opacity="0.55"/>

  {# ============ LABEL SLAB - 7 SMPTE PRIMARIES per RP 219 ============ #}
  <g class="{{ uid }}-bars {{ uid }}-glitch" clip-path="url(#{{ uid }}-bars-clip)">
    <rect x="2"   y="2" width="17" height="28" fill="#C0C0C0"/>
    <rect x="19"  y="2" width="17" height="28" fill="#C0C000"/>
    <rect x="36"  y="2" width="17" height="28" fill="#00C0C0"/>
    <rect x="53"  y="2" width="17" height="28" fill="#00C000"/>
    <rect x="70"  y="2" width="17" height="28" fill="#C000C0"/>
    <rect x="87"  y="2" width="17" height="28" fill="#C00000"/>
    <rect x="104" y="2" width="15" height="28" fill="#0000C0"/>
  </g>

  {# scanline + horizontal noise (clipped to bars) #}
  <g clip-path="url(#{{ uid }}-bars-clip)">
    <rect class="{{ uid }}-flick1" x="2" y="8"  width="117" height="0.5" fill="#FFFFFF"/>
    <rect class="{{ uid }}-flick2" x="2" y="20" width="117" height="0.5" fill="#FFFFFF"/>
    <rect class="{{ uid }}-scan"   x="2" y="2"  width="117" height="0.8" fill="#FFFFFF" opacity="0.22"/>
  </g>

  {# black NO SIGNAL banner (the meme) #}
  <rect x="14" y="9" width="93" height="14" fill="#000000"
        stroke="#FFFFFF" stroke-opacity="0.22" stroke-width="0.5"/>
  <text x="60.5" y="20" text-anchor="middle"
        font-family="'Orbitron',sans-serif" font-size="8.5" font-weight="900"
        fill="#FFFFFF" letter-spacing="0.18em">NO SIGNAL</text>

  {# ============ REFINED SEAM ============ #}
  <rect x="119" y="2" width="1" height="28" fill="url(#{{ uid }}-seam)"/>
  <rect x="120" y="2" width="2" height="28" fill="#020308"/>

  {# ============ VALUE SLAB - ERROR CODE ============ #}
  <rect x="122" y="2" width="68" height="28" fill="url(#{{ uid }}-vb)"/>
  <text class="{{ uid }}-err" x="156" y="21" text-anchor="middle"
        font-family="'Chakra Petch',sans-serif" font-size="12" font-weight="700"
        fill="#FF6B7E" letter-spacing="0.06em">ERR_{{ status_code }}</text>
</svg>
