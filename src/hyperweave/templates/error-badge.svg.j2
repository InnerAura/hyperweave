{# HyperWeave Error Badge — minimal fallback SVG for HTTP error responses. #}
<svg xmlns="http://www.w3.org/2000/svg" width="200" height="22" role="img">
  <rect width="200" height="22" rx="3" fill="#1C1C1C" stroke="#EF4444" stroke-width="1"/>
  <text x="100" y="15" text-anchor="middle" fill="#EF4444"
        font-size="10" font-family="monospace">{{ message }}</text>
</svg>
