{# Primer top-plane catchlight — dark substrate only. A THIN highlight (white
   0.06 → 0.014 by 22%) that fades to nothing well before the midline, so it reads
   as a glint on the top edge, not a veil. Referenced ONLY by the badge defs — the
   larger frames (strip, stats, chart, marquee) carry their own structural depth and
   wash out under any surface gloss. The badge fills a rect with url(#{{ uid }}-gloss).
   Gated on `not panel_gradient_stops` — light substrates have their own white ground. #}
{% if not panel_gradient_stops %}<linearGradient id="{{ uid }}-gloss" x1="0" y1="0" x2="0" y2="1">
  <stop offset="0%" stop-color="white" stop-opacity="0.06"/>
  <stop offset="22%" stop-color="white" stop-opacity="0.014"/>
  <stop offset="100%" stop-color="white" stop-opacity="0"/>
</linearGradient>
{% endif %}
