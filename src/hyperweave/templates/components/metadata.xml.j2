{# HyperWeave tiered metadata XML block.
   Rendered by _build_metadata_xml() in engine.py.
   Tier 0 = empty (handled in Python), Tier 1+ rendered here. #}
<metadata>
  <hw:artifact id="{{ artifact_id }}" type="{{ spec_type }}" series="{{ series }}" version="0.1.0"
               xmlns:hw="https://hyperweave.dev/hw/v8.0">
    <hw:provenance>
      <hw:generator>HyperWeave Compositor v0.1 (InnerAura Labs)</hw:generator>
      <hw:created>{{ now }}</hw:created>
      <hw:human-directed>true</hw:human-directed>
    </hw:provenance>
    <hw:spec size="{{ width }}x{{ height }}" performance="composite-only" theme="{{ category }}" a11y="WCAG-AA"/>
{% if metadata_tier >= 2 %}
    <hw:composition>
      <hw:frame>{{ spec_type }}</hw:frame>
      <hw:genome>{{ genome_id }}@0.1.0</hw:genome>
      <hw:profile>{{ profile_id }}</hw:profile>
      <hw:environment platform="{{ platform }}" motion="{{ motion }}" status="{{ state }}" regime="{{ regime }}"/>
    </hw:composition>
{% endif %}
{% if metadata_tier >= 3 %}
    <hw:aesthetic>
      <hw:chromatic system="{{ genome_id }}" space="oklch"/>
      <hw:motion vocabulary="{{ motion }}"/>
      <hw:material surface="genome-native"/>
    </hw:aesthetic>
{% endif %}
{% if metadata_tier >= 3 and (intent or approach or tradeoffs) %}
    <hw:reasoning>
      <hw:intent>{{ intent | xml_escape }}</hw:intent>
      <hw:approach>{{ approach | xml_escape }}</hw:approach>
      <hw:tradeoffs>{{ tradeoffs | xml_escape }}</hw:tradeoffs>
    </hw:reasoning>
{% endif %}
  </hw:artifact>
</metadata>