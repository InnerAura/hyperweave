  "variant_phenomenology": {
    "noir": "ink dissolved to its limit \u2014 paper darkened past return",
    "carbon": "graphite warmed by a struck ember \u2014 monochrome with one flame",
    "space": "the observatory window at night \u2014 deep field, cold signal",
    "anvil": "machined billet under shop light \u2014 neutral steel, no tint",
    "porcelain": "fired white glaze, cobalt underglaze \u2014 the editorial default",
    "cream": "laid paper and warm brass \u2014 the letterpress proof",
    "dusk": "the last mauve light before the lamps \u2014 quiet rose on bone",
    "petrol": "patinated copper on sea-glass \u2014 teal weathered calm"
  },
